---
# ==============================================================================
# .clang-format configuration for CryEngine 2 (Hybrid C++ & HLSL Shaders)
# ==============================================================================
Language: Cpp
BasedOnStyle: LLVM
Standard: Latest

# ==============================================================================
# --- Tabs, Spaces & Indentation (Uncrustify Matched) ---
# ==============================================================================
UseTab: ForIndentation
TabWidth: 2
IndentWidth: 2
ContinuationIndentWidth: 2
ColumnLimit: 120
MaxEmptyLinesToKeep: 2
InsertNewlineAtEOF: true

# Outdent public/private/protected by 1 tab (-2 spaces)
AccessModifierOffset: -2

# ==============================================================================
# --- Braces & Control Statements (ALLMAN STYLE) ---
# ==============================================================================
BreakBeforeBraces: Custom
BraceWrapping:
  AfterCaseLabel: true
  AfterClass: true
  AfterControlStatement: Always
  AfterEnum: true
  AfterFunction: true
  AfterNamespace: true
  AfterStruct: true
  AfterUnion: true
  AfterExternBlock: true
  BeforeCatch: true
  BeforeElse: true
  BeforeLambdaBody: false
  IndentBraces: false

IndentCaseLabels: false

# CryEngine allows single-liners ONLY for getters/setters in headers
AllowShortFunctionsOnASingleLine: InlineOnly
AllowShortBlocksOnASingleLine: Empty
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false
AllowShortEnumsOnASingleLine: false

# ==============================================================================
# --- Alignment & Wrapping (ENGINEERING STYLE) ---
# ==============================================================================
AlignConsecutiveAssignments:
  Enabled: true
  AcrossEmptyLines: false
  AcrossComments: false
  AlignCompound: true

AlignConsecutiveDeclarations:
  Enabled: true
  AcrossEmptyLines: false
  AcrossComments: false

AlignConsecutiveMacros: true

AlignAfterOpenBracket: DontAlign
AlignOperands: DontAlign
BreakConstructorInitializers: BeforeComma
ConstructorInitializerIndentWidth: 2
BreakBeforeTernaryOperators: true

# ==============================================================================
# --- Spaces & Pointers ---
# ==============================================================================
PointerAlignment: Left                       # Type* name
ReferenceAlignment: Left                     # Type& name

SpaceAfterCStyleCast: false
SpaceAfterTemplateKeyword: true
SpaceBeforeAssignmentOperators: true
SpaceBeforeParens: ControlStatements
SpacesInCStyleCastParentheses: false
SpacesInParentheses: false
SpacesInSquareBrackets: false

# CRITICAL: Do not format inside < > to protect UI blocks in HLSL & C++ Templates
SpacesInAngles: Leave

# ==============================================================================
# --- Namespaces & Sorting ---
# ==============================================================================
CompactNamespaces: false
NamespaceIndentation: None
SortIncludes: CaseInsensitive
SortUsingDeclarations: true

# ==============================================================================
# --- C++ CryEngine Specifics ---
# ==============================================================================
# Tells clang-format to treat these macros exactly like the 'if' keyword
IfMacros:
  - 'IF'
  - 'IF_LIKELY'
  - 'IF_UNLIKELY'

# ==============================================================================
# --- HLSL & C++ Macros Protections ---
# ==============================================================================

# 1. Macro Blocks
MacroBlockBegin: "^(CB_BEGIN|CBUFFER_BEGIN|BEGIN_[A-Z0-9_]+|DECLARE_.*_BEGIN)$"
MacroBlockEnd: "^(CB_END|CBUFFER_END|END_[A-Z0-9_]+|DECLARE_.*_END)$"

# 2. Statement Macros (HLSL passes & Engine calls)
StatementMacros:
  - 'technique'
  - 'pass'
  - 'DECLARE_TEXTURE'
  - 'DECLARE_SAMPLER'
  - 'REGISTER_SAMPLER'
  - 'DECLARE_CB'
  - 'IN_P'
  - 'IN_TBASE'
  - 'IN_C0'
  - 'OUT_C0'
  - 'IN_TANG_STREAM'
  - 'INST_STREAM_POS'
  - 'INST_STREAM_CUSTOM'
  - 'IN_SKIN_STREAM'
  - 'IN_SHAPEDEFORM_STREAM'
  - 'IN_MORPHTARGET_STREAM'

# 3. Attribute Macros (Protecting HLSL Semantics & C++ Memory Alignments)
AttributeMacros:
  - 'CRY_ALIGN'                              # C++ Memory alignment macro
  - 'register'
  - 'packoffset'
  - 'numthreads'
  - 'maxvertexcount'
  - 'STANDARDSGLOBAL'
  - 'PI_Composite'
  - 'PI_NumInstructions'
  - 'PB_CameraFront'
  - 'PB_RTRect'
  - 'PB_ScreenSize'
  - 'SV_Target'
  - 'SV_Position'
  - 'SV_Depth'
  - 'POSITION'
  - 'DEPTH'
  - 'COLOR0'
  - 'COLOR1'
  - 'TEXCOORDN'
  - 'TEXCOORD0'
  - 'TEXCOORD1'
  - 'TEXCOORD2'
  - 'TEXCOORD3'
  - 'TEXCOORD4'
  - 'TEXCOORD5'
  - 'TEXCOORD0_centroid'
  - 'TEXCOORD1_centroid'
  - 'TEXCOORD2_centroid'
  - 'NORMAL'
  - 'TANGENT'
  - 'BINORMAL'
  - 'BLENDWEIGHT'
  - 'BLENDINDICES'

# 4. Typename Macros (HLSL Types & C++ Custom Types)
TypenameMacros:
  - 'cbuffer'
  - 'sampler_state'
  - 'sampler1D'
  - 'sampler2D'
  - 'sampler3D'
  - 'samplerCUBE'
  - 'Texture1D'
  - 'Texture2D'
  - 'Texture3D'
  - 'TextureCube'
  - 'Texture2DArray'
  - 'RWTexture1D'
  - 'RWTexture2D'
  - 'RWTexture3D'
  - 'SamplerState'
  - 'SamplerComparisonState'
  - 'ConstantBuffer'
  - 'StructuredBuffer'
  - 'RWStructuredBuffer'
  - 'ByteAddressBuffer'
  - 'RWByteAddressBuffer'
  - 'AppendStructuredBuffer'
  - 'ConsumeStructuredBuffer'
  - 'float2'
  - 'float3'
  - 'float4'
  - 'float2x2'
  - 'float3x3'
  - 'float4x4'
  - 'half2'
  - 'half3'
  - 'half4'
  - 'half2x2'
  - 'half3x3'
  - 'half4x4'
  - 'uint2'
  - 'uint3'
  - 'uint4'
  - 'int2'
  - 'int3'
  - 'int4'
  - 'bool2'
  - 'bool3'
  - 'bool4'
  - 'pixout'
  - 'pixout_cl'
  - 'pixout2'
  - 'vtxIn'
  - 'vtxOut'
