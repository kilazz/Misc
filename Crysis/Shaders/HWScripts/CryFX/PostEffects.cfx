    }
}

struct vtxOutAA
{
    float4 HPosition    : POSITION;
    float2 baseTC       : TEXCOORDN;
    float4 baseTCmY     : TEXCOORDN;
    float4 baseTCpX     : TEXCOORDN;
    float4 baseTCpY     : TEXCOORDN;
    float4 baseTCmX     : TEXCOORDN;
    float4 RotatedGridX : TEXCOORDN;
    float4 RotatedGridY : TEXCOORDN;
};

struct vtxOutAAOpt
{
    float4 HPosition : POSITION;
    float2 baseTC    : TEXCOORDN;
    float2 baseTC0   : TEXCOORDN;
    float2 baseTC1   : TEXCOORDN;
    float2 baseTC2   : TEXCOORDN;
};

vtxOutAA EdgeAAVS(vtxIn IN)
{
    vtxOutAA OUT = (vtxOutAA)0;

    float4 vPos   = IN.Position;
    OUT.HPosition = mul(vpMatrix, vPos);
    OUT.baseTC.xy = IN.baseTC.xy;

    half2 ddX = RotGridScreenOffset.xy;
    half2 ddY = RotGridScreenOffset.zw;

    OUT.baseTCmY.xy = IN.baseTC.xy - ddY.xy;
    OUT.baseTCpX.xy = IN.baseTC.xy + ddX.xy;
    OUT.baseTCpY.xy = IN.baseTC.xy + ddY.xy;
    OUT.baseTCmX.xy = IN.baseTC.xy - ddX.xy;

    OUT.RotatedGridX = 0.66f * float4(-ddY.x, ddX.x, ddY.x, -ddX.x);
    OUT.RotatedGridY = 0.66f * float4(-ddY.y, ddX.y, ddY.y, -ddX.y);

    return OUT;
}

vtxOutAAOpt EdgeAAOptVS(vtxIn IN)
{
    vtxOutAAOpt OUT = (vtxOutAAOpt)0;

    float4 vPos   = IN.Position;
    OUT.HPosition = mul(vpMatrix, vPos);
    OUT.baseTC.xy = IN.baseTC.xy;

    float2 offset0 = float2(-0.939f, 0.342f);
    float2 offset1 = float2(0.342f, -0.939f);

    OUT.baseTC0.xy = IN.baseTC.xy - 2.0f * g_VS_ScreenSize.zw * (offset0 + offset1);
    OUT.baseTC1.xy = IN.baseTC.xy + 2.0f * g_VS_ScreenSize.zw * offset0;
    OUT.baseTC2.xy = IN.baseTC.xy + 2.0f * g_VS_ScreenSize.zw * offset1;

    return OUT;
}

pixout EdgePS(vtxOutAA IN)
{
    pixout OUT;

#if D3D10
    // temporary workaround for d3d10 hlsl compiler bug
#endif

    half3 LUMINANCE_VECTOR = half3(0.2125f, 0.7154f, 0.0721f);
    half4 vSample          = tex2D(_tex0, IN.baseTC.xy);

    bool enableFXAA = true;

    if (enableFXAA)
    {
        float2 invScreen = 1.0f / PS_ScreenSize.xy;

        half3 nw = tex2D(_tex0, IN.baseTC.xy + float2(-1.0f, -1.0f) * invScreen).rgb;
        half3 ne = tex2D(_tex0, IN.baseTC.xy + float2( 1.0f, -1.0f) * invScreen).rgb;
        half3 sw = tex2D(_tex0, IN.baseTC.xy + float2(-1.0f,  1.0f) * invScreen).rgb;
        half3 se = tex2D(_tex0, IN.baseTC.xy + float2( 1.0f,  1.0f) * invScreen).rgb;

        half lumaNW = dot(nw, LUMINANCE_VECTOR);
        half lumaNE = dot(ne, LUMINANCE_VECTOR);
        half lumaSW = dot(sw, LUMINANCE_VECTOR);
        half lumaSE = dot(se, LUMINANCE_VECTOR);
        half lumaM  = dot(vSample.rgb, LUMINANCE_VECTOR);

        float2 dir;
        dir.x = -((lumaNW + lumaNE) - (lumaSW + lumaSE));
        dir.y = ((lumaNW + lumaSW) - (lumaNE + lumaSE));

        half dirReduce = max((lumaNW + lumaNE + lumaSW + lumaSE) * 0.015625f, 0.0078125f);
        half rcpDirMin = 1.0f / (min(abs(dir.x), abs(dir.y)) + dirReduce);

        dir = clamp(dir * rcpDirMin, -8.0f, 8.0f) * invScreen;

        half3 rgbA = 0.5f * (tex2D(_tex0, IN.baseTC.xy - dir * 0.166667f).rgb +
                             tex2D(_tex0, IN.baseTC.xy + dir * 0.166667f).rgb);

        half3 rgbB = rgbA * 0.5f + 0.25f * (tex2D(_tex0, IN.baseTC.xy - dir * 0.5f).rgb +
                                            tex2D(_tex0, IN.baseTC.xy + dir * 0.5f).rgb);

        half lumaB   = dot(rgbB, LUMINANCE_VECTOR);
        half lumaMin = min(lumaM, min(min(lumaNW, lumaNE), min(lumaSW, lumaSE)));
        half lumaMax = max(lumaM, max(max(lumaNW, lumaNE), max(lumaSW, lumaSE)));

        if ((lumaB < lumaMin) || (lumaB > lumaMax))
        {
            vSample.rgb = rgbA;
        }
        else
        {
            vSample.rgb = rgbB;
        }
    }

    bool enableRCAS = true;

    if (enableRCAS)
    {
        float2 rcasOffset = 1.0f / PS_ScreenSize.xy;
        half3  c          = vSample.rgb;

        half3 t = tex2D(_tex0, IN.baseTC.xy + float2(0.0f, -rcasOffset.y)).rgb;
        half3 b = tex2D(_tex0, IN.baseTC.xy + float2(0.0f, rcasOffset.y)).rgb;
        half3 l = tex2D(_tex0, IN.baseTC.xy + float2(-rcasOffset.x, 0.0f)).rgb;
        half3 r = tex2D(_tex0, IN.baseTC.xy + float2(rcasOffset.x, 0.0f)).rgb;

        half Sharpness = 0.4f;
        half Limit     = 0.1875f;

        half3 minNeighbor = min(min(t, b), min(l, r));
        half3 maxNeighbor = max(max(t, b), max(l, r));
        half3 minColor    = min(minNeighbor, c);
        half3 maxColor    = max(maxNeighbor, c);

        half3 limitAmp  = min(minColor, 1.0f - maxColor) / max(maxColor, 0.00001f);
        limitAmp        = saturate(limitAmp * limitAmp);
        limitAmp       *= Limit;

        half w      = Sharpness * limitAmp;
        vSample.rgb = (c + w * (t + b + l + r)) / (1.0f + 4.0f * w);
    }

    OUT.Color = vSample;

    return OUT;
}

pixout EdgePS2PixelBlurTest(vtxOutAA IN)
{
    pixout OUT;

#if D3D10
    // temporary workaround for d3d10 hlsl compiler bug
    OUT.Color = tex2D(_tex0, IN.baseTC.xy);
#endif

    half dep = tex2D(_tex1, IN.baseTC.xy).x;

    half depUp     = tex2D(_tex1, IN.baseTCmY.xy).x;
    half depRight  = tex2D(_tex1, IN.baseTCpX.xy).x;
    half depDown   = tex2D(_tex1, IN.baseTCpY.xy).x;
    half depLeft   = tex2D(_tex1, IN.baseTCmX.xy).x;

    half4 samples  = half4(depUp, depRight, depDown, depLeft) - dep;
    half4 samples2 = dep - half4(depUp, depRight, depDown, depLeft);

    half threshold = 0.03f * dep;

    samples2 = step(threshold, samples2);
    samples  = step(threshold, samples);
    samples  = saturate(samples + samples2);

    half sum = dot(samples, 1.0f);

    half4 colCenter = tex2D(_tex0, IN.baseTC.xy);
    half4 colUp     = tex2D(_tex0, IN.baseTCmY.xy);
    half4 colRight  = tex2D(_tex0, IN.baseTCpX.xy);
    half4 colDown   = tex2D(_tex0, IN.baseTCpY.xy);
    half4 colLeft   = tex2D(_tex0, IN.baseTCmX.xy);

    half4 resCol = colCenter * 2.0f;
    resCol      += colUp * samples.x;
    resCol      += colRight * samples.y;
    resCol      += colDown * samples.z;
    resCol      += colLeft * samples.w;
    resCol      *= 1.0f / (sum + 2.0f);

    OUT.Color.xyz = resCol.xyz;
    OUT.Color.w   = colCenter.w;

    return OUT;
}

pixout EdgePS2PixelBlurTestOpt(vtxOutAAOpt IN)
{
    pixout OUT;

#if D3D10
    // temporary workaround for d3d10 hlsl compiler bug
    OUT.Color = tex2D(_tex0, IN.baseTC.xy);
#endif

    half sampleDepthUp    = tex2D(_tex1, IN.baseTC0.xy).x;
    half sampleDepthRight = tex2D(_tex1, IN.baseTC1.xy).x;
    half sampleDepthDown  = tex2D(_tex1, IN.baseTC2.xy).x;

    half dep = tex2D(_tex1, IN.baseTC.xy).x;

    half3 samples  = half3(sampleDepthUp, sampleDepthRight, sampleDepthDown) - dep;
    half3 samples2 = dep - half3(sampleDepthUp, sampleDepthRight, sampleDepthDown);

    half threshold = 0.003f * dep;

    samples2 = step(threshold, samples2);
    samples  = step(threshold, samples);
    samples  = saturate(samples + samples2);

    half fRecipSum = 1.0f / dot(samples, 1.0f);

    float2 avgTC = (IN.baseTC.xy * 2.0f +
                    IN.baseTC0.xy * samples.x +
                    IN.baseTC1.xy * samples.y +
                    IN.baseTC2.xy * samples.z) * fRecipSum;

    half4 cSampleAvg = tex2D(_tex0, avgTC);

    OUT.Color = cSampleAvg;

    return OUT;
}

technique EdgeAA
{
    pass p0
    {
        CullMode = None;
#ifdef PS30
        VertexShader = compile vs_3_0 EdgeAAVS();
        PixelShader  = compile ps_3_0 EdgePS();
#else
        VertexShader = compile vs_2_0 EdgeAAVS();
        PixelShader  = compile ps_2_0 EdgePS();
#endif
    }
}

technique EdgeBlur
{
    pass p0
    {
        CullMode     = None;
        VertexShader = compile vs_2_0 EdgeAAVS();
        PixelShader  = compile ps_2_0 EdgePS2PixelBlurTest();
    }
}

technique EdgeBlurOpt
{
    pass p0
    {
        CullMode     = None;
        VertexShader = compile vs_2_0 EdgeAAOptVS();
        PixelShader  = compile ps_2_0 EdgePS2PixelBlurTestOpt();
    }
}

float4 clrScrParams;

struct vtxOutClrScr
{
    float4 HPosition : POSITION;
};

vtxOutClrScr ClearScreenVS(vtxIn IN)
{
    vtxOutClrScr OUT = (vtxOutClrScr)0;

    OUT.HPosition = mul(vpMatrix, IN.Position);

    return OUT;
}

pixout ClearScreenPS(vtxOutClrScr IN)
{
    pixout OUT;

    OUT.Color = clrScrParams;

    return OUT;
}

technique ClearScreen
{
    pass p0
    {
        VertexShader = compile vs_Auto ClearScreenVS();
        PixelShader  = compile ps_Auto ClearScreenPS();
        CullMode     = None;
    }
}

float4 blurParams0;
float4 blurParams1;

sampler2D blurMap0 : register(s0);

struct vtxOutKawase
{
    float4 HPosition : POSITION;
    float2 baseTC0   : TEXCOORDN;
    float2 baseTC1   : TEXCOORDN;
    float2 baseTC2   : TEXCOORDN;
    float2 baseTC3   : TEXCOORDN;
    float2 baseTC4   : TEXCOORDN;
};

vtxOutKawase KawaseBlurVS(vtxIn IN)
{
    vtxOutKawase OUT = (vtxOutKawase)0;

    float4 vPos   = IN.Position;
    OUT.HPosition = mul(vpMatrix, vPos);

    OUT.baseTC0.xy = IN.baseTC.xy;
    OUT.baseTC1.xy = IN.baseTC.xy + blurParams0.xy;
    OUT.baseTC2.xy = IN.baseTC.xy + blurParams0.zw;
    OUT.baseTC3.xy = IN.baseTC.xy + blurParams1.xy;
    OUT.baseTC4.xy = IN.baseTC.xy + blurParams1.zw;

    return OUT;
}

pixout KawaseBlurPS(vtxOutKawase IN)
{
    pixout OUT;

    half4 baseColor0 = tex2D(blurMap0, IN.baseTC0.xy);
    half4 baseColor1 = tex2D(blurMap0, IN.baseTC1.xy);
    half4 baseColor2 = tex2D(blurMap0, IN.baseTC2.xy);
    half4 baseColor3 = tex2D(blurMap0, IN.baseTC3.xy);
    half4 baseColor4 = tex2D(blurMap0, IN.baseTC4.xy);

    OUT.Color = (baseColor0 + baseColor1 + baseColor2 + baseColor3 + baseColor4) * 0.2f;

    return OUT;
}

technique KawaseBlur
{
    pass p0
    {
        VertexShader = compile vs_Auto KawaseBlurVS();
        PixelShader  = compile ps_Auto KawaseBlurPS();
        CullMode     = Back;
    }
}

float4 PI_psOffsets[16];
float4 psWeights[16];

struct vtxOutGauss
{
    float4 HPosition : POSITION;
    float4 tc0       : TEXCOORDN;
    float4 tc1       : TEXCOORDN;
    float2 tc2       : TEXCOORDN;
    float2 tc3       : TEXCOORDN;
    float2 tc4       : TEXCOORDN;
    float2 tc5       : TEXCOORDN;
    float2 tc6       : TEXCOORDN;
    float2 tc7       : TEXCOORDN;
};

vtxOutGauss GaussBlurBilinearVS(vtxIn IN)
{
    vtxOutGauss OUT = (vtxOutGauss)0;

    float4 vPos   = IN.Position;
    OUT.HPosition = mul(vpMatrix, vPos);

    OUT.tc0.xy = IN.baseTC.xy + PI_psOffsets[0].xy;
    OUT.tc1.xy = IN.baseTC.xy + PI_psOffsets[1].xy;
    OUT.tc2.xy = IN.baseTC.xy + PI_psOffsets[2].xy;
    OUT.tc3.xy = IN.baseTC.xy + PI_psOffsets[3].xy;
    OUT.tc4.xy = IN.baseTC.xy + PI_psOffsets[4].xy;
    OUT.tc5.xy = IN.baseTC.xy + PI_psOffsets[5].xy;
    OUT.tc6.xy = IN.baseTC.xy + PI_psOffsets[6].xy;
    OUT.tc7.xy = IN.baseTC.xy + PI_psOffsets[7].xy;

    OUT.tc0.wz = IN.baseTC.xy;
    OUT.tc1.wz = (IN.baseTC.xy - 0.5f) * float2(0.75f * (ScrSize.x / ScrSize.y), 1.0f) + 0.5f;

    return OUT;
}

pixout GaussBlurBilinearPS(vtxOutGauss IN)
{
    pixout OUT;

    half4 sum = 0.0f;

    sum += tex2D(_tex0, IN.tc0.xy) * (half)psWeights[0].x;
    sum += tex2D(_tex0, IN.tc1.xy) * (half)psWeights[1].x;
    sum += tex2D(_tex0, IN.tc2.xy) * (half)psWeights[2].x;
    sum += tex2D(_tex0, IN.tc3.xy) * (half)psWeights[3].x;
    sum += tex2D(_tex0, IN.tc4.xy) * (half)psWeights[4].x;
    sum += tex2D(_tex0, IN.tc5.xy) * (half)psWeights[5].x;
    sum += tex2D(_tex0, IN.tc6.xy) * (half)psWeights[6].x;
    sum += tex2D(_tex0, IN.tc7.xy) * (half)psWeights[7].x;

    OUT.Color = sum;

    return OUT;
}

pixout MaskedGaussBlurBilinearPS(vtxOutGauss IN)
{
    pixout OUT;

    half4 sum  = 0.0f;
    half4 orig = tex2D(_tex0, IN.tc0.wz);
    half  mask = tex2D(_tex1, IN.tc1.wz).x;

    sum += lerp(orig, tex2D(_tex0, IN.tc0.xy), mask) * (half)psWeights[0].x;
    sum += lerp(orig, tex2D(_tex0, IN.tc1.xy), mask) * (half)psWeights[1].x;
    sum += lerp(orig, tex2D(_tex0, IN.tc2.xy), mask) * (half)psWeights[2].x;
    sum += lerp(orig, tex2D(_tex0, IN.tc3.xy), mask) * (half)psWeights[3].x;
    sum += lerp(orig, tex2D(_tex0, IN.tc4.xy), mask) * (half)psWeights[4].x;
    sum += lerp(orig, tex2D(_tex0, IN.tc5.xy), mask) * (half)psWeights[5].x;
    sum += lerp(orig, tex2D(_tex0, IN.tc6.xy), mask) * (half)psWeights[6].x;
    sum += lerp(orig, tex2D(_tex0, IN.tc7.xy), mask) * (half)psWeights[7].x;

    OUT.Color = sum;

    return OUT;
}

pixout GaussBlurBilinearEncodedPS(vtxOutGauss IN)
{
    pixout OUT;

    half3 sum = 0.0f;

    sum += DecodeRGBS(tex2D(_tex0, IN.tc0.xy)) * (half)psWeights[0].x;
    sum += DecodeRGBS(tex2D(_tex0, IN.tc1.xy)) * (half)psWeights[1].x;
    sum += DecodeRGBS(tex2D(_tex0, IN.tc2.xy)) * (half)psWeights[2].x;
    sum += DecodeRGBS(tex2D(_tex0, IN.tc3.xy)) * (half)psWeights[3].x;
    sum += DecodeRGBS(tex2D(_tex0, IN.tc4.xy)) * (half)psWeights[4].x;
    sum += DecodeRGBS(tex2D(_tex0, IN.tc5.xy)) * (half)psWeights[5].x;
    sum += DecodeRGBS(tex2D(_tex0, IN.tc6.xy)) * (half)psWeights[6].x;
    sum += DecodeRGBS(tex2D(_tex0, IN.tc7.xy)) * (half)psWeights[7].x;

    OUT.Color = EncodeRGBS(float4(sum.xyz, 1.0f));

    return OUT;
}

pixout GaussBlurPS(vtxOut IN)
{
    pixout OUT;

    int   samples = 16;
    half4 sum     = 0.0f;

    for (int i = 0; i < samples; i++)
    {
        half4 col  = tex2D(_tex0, IN.baseTC.xy + PI_psOffsets[i].xy);
        sum       += col * psWeights[i];
    }

    OUT.Color = sum;

    return OUT;
}

technique GaussBlur
{
    pass p0
    {
        VertexShader = compile vs_Auto BaseVS();
        PixelShader  = compile ps_Auto GaussBlurPS();
    }
}

technique GaussBlurBilinear
{
    pass p0
    {
        VertexShader = compile vs_Auto GaussBlurBilinearVS();
        PixelShader  = compile ps_Auto GaussBlurBilinearPS();
    }
}

technique MaskedGaussBlurBilinear
{
    pass p0
    {
        VertexShader = compile vs_Auto GaussBlurBilinearVS();
        PixelShader  = compile ps_Auto MaskedGaussBlurBilinearPS();
    }
}

technique GaussBlurBilinearEncoded
{
    pass p0
    {
        VertexShader = compile vs_Auto GaussBlurBilinearVS();
        PixelShader  = compile ps_Auto GaussBlurBilinearEncodedPS();
    }
}

struct vtxOutAlphaBlur
{
    float4 HPosition : POSITION;
    float4 tc0       : TEXCOORDN;
    float2 tc1       : TEXCOORDN;
    float2 tc2       : TEXCOORDN;
    float2 tc3       : TEXCOORDN;
    float2 tc4       : TEXCOORDN;
    float2 tc5       : TEXCOORDN;
    float2 tc6       : TEXCOORDN;
    float2 tc7       : TEXCOORDN;
};

vtxOutAlphaBlur GaussAlphaBlurVS(vtxIn IN)
{
    vtxOutAlphaBlur OUT = (vtxOutAlphaBlur)0;

    float4 vPos   = IN.Position;
    OUT.HPosition = mul(vpMatrix, vPos);

    OUT.tc0.zw = IN.baseTC.xy;
    OUT.tc0.xy = IN.baseTC.xy + PI_psOffsets[0].xy;
    OUT.tc1.xy = IN.baseTC.xy + PI_psOffsets[1].xy;
    OUT.tc2.xy = IN.baseTC.xy + PI_psOffsets[2].xy;
    OUT.tc3.xy = IN.baseTC.xy + PI_psOffsets[3].xy;
    OUT.tc4.xy = IN.baseTC.xy + PI_psOffsets[4].xy;
    OUT.tc5.xy = IN.baseTC.xy + PI_psOffsets[5].xy;
    OUT.tc6.xy = IN.baseTC.xy + PI_psOffsets[6].xy;
    OUT.tc7.xy = IN.baseTC.xy + PI_psOffsets[7].xy;

    return OUT;
}

pixout GaussAlphaBlurPS(vtxOutAlphaBlur IN)
{
    pixout OUT;

    half sum = 0.0f;

    sum += tex2D(_tex0, IN.tc0.xy).a * (half)psWeights[0].x;
    sum += tex2D(_tex0, IN.tc1.xy).a * (half)psWeights[1].x;
    sum += tex2D(_tex0, IN.tc2.xy).a * (half)psWeights[2].x;
    sum += tex2D(_tex0, IN.tc3.xy).a * (half)psWeights[3].x;
    sum += tex2D(_tex0, IN.tc4.xy).a * (half)psWeights[4].x;
    sum += tex2D(_tex0, IN.tc5.xy).a * (half)psWeights[5].x;
    sum += tex2D(_tex0, IN.tc6.xy).a * (half)psWeights[6].x;
    sum += tex2D(_tex0, IN.tc7.xy).a * (half)psWeights[7].x;

    OUT.Color.xyz = tex2D(_tex0, IN.tc0.zw).xyz;
    OUT.Color.a   = sum;

    return OUT;
}

technique GaussAlphaBlur
{
    pass p0
    {
        VertexShader = compile vs_Auto GaussAlphaBlurVS();
        PixelShader  = compile ps_Auto GaussAlphaBlurPS();
    }
}

struct vtxOutAnisotropicVertical
{
    float4 HPosition : POSITION;
    float2 baseTC0 : TEXCOORDN;
    float2 baseTC1 : TEXCOORDN;
    float2 baseTC2 : TEXCOORDN;
    float2 baseTC3 : TEXCOORDN;
    float2 baseTC4 : TEXCOORDN;
    float2 baseTC5 : TEXCOORDN;
    float2 baseTC6 : TEXCOORDN;
    float2 baseTC7 : TEXCOORDN;
};

vtxOutAnisotropicVertical AnisotropicVerticalVS(vtxIn IN)
{
    vtxOutAnisotropicVertical OUT = (vtxOutAnisotropicVertical)0;

    float4 vPos   = IN.Position;
    OUT.HPosition = mul(vpMatrix, vPos);

    float scalePos = 0.125f * 0.75f;
    float scaleNeg = 0.75f;

    OUT.baseTC0.xy = IN.baseTC.xy + float2(0.0f, blurParams0.x) * scalePos;
    OUT.baseTC1.xy = IN.baseTC.xy + float2(0.0f, blurParams0.y) * scalePos;
    OUT.baseTC2.xy = IN.baseTC.xy + float2(0.0f, blurParams0.z) * scalePos;
    OUT.baseTC3.xy = IN.baseTC.xy + float2(0.0f, blurParams0.w) * scalePos;

    OUT.baseTC4.xy = IN.baseTC.xy - float2(0.0f, blurParams0.x) * scaleNeg;
    OUT.baseTC5.xy = IN.baseTC.xy - float2(0.0f, blurParams0.y) * scaleNeg;
    OUT.baseTC6.xy = IN.baseTC.xy - float2(0.0f, blurParams0.z) * scaleNeg;
    OUT.baseTC7.xy = IN.baseTC.xy - float2(0.0f, blurParams0.w) * scaleNeg;

    return OUT;
}

pixout AnisotropicVerticalBlurPS(vtxOutAnisotropicVertical IN)
{
    pixout OUT;

    float4 canis  = tex2D(blurMap0, IN.baseTC0.xy);
    canis        += tex2D(blurMap0, IN.baseTC1.xy);
    canis        += tex2D(blurMap0, IN.baseTC2.xy);
    canis        += tex2D(blurMap0, IN.baseTC3.xy);
    canis        += tex2D(blurMap0, IN.baseTC4.xy);
    canis        += tex2D(blurMap0, IN.baseTC5.xy);
    canis        += tex2D(blurMap0, IN.baseTC6.xy);
    canis        += tex2D(blurMap0, IN.baseTC7.xy);

    OUT.Color = canis * 0.125f;

    return OUT;
}

technique AnisotropicVertical
{
    pass p0
    {
        VertexShader = compile vs_Auto AnisotropicVerticalVS();
        PixelShader  = compile ps_Auto AnisotropicVerticalBlurPS();
        CullMode     = Back;
    }
}

float4 vPixelOffset;
float4 vDilateParams;

struct vtxInDilate
{
    IN_P
    IN_TBASE
    IN_C0
};

struct vtxOutDilate
{
    float4 HPosition : POSITION;
    float2 baseTC    : TEXCOORD0;
};

vtxOutDilate DilateVS(vtxInDilate IN)
{
    vtxOutDilate OUT = (vtxOutDilate)0;

    float4 vPos   = IN.Position;
    OUT.HPosition = mul(vpMatrix, vPos);
    OUT.baseTC.xy = IN.baseTC.xy + 0.00001f;

    return OUT;
}

pixout DilatePS(vtxOutDilate IN)
{
    pixout OUT;

    const float2 Kernel_Neighbors[20] =
    {
        float2(-1.0f,  0.0f), float2( 1.0f,  0.0f), float2( 0.0f, -1.0f), float2( 0.0f,  1.0f),
        float2(-1.0f, -1.0f), float2(-1.0f,  1.0f), float2( 1.0f, -1.0f), float2( 1.0f,  1.0f),
        float2(-2.0f,  0.0f), float2( 2.0f,  0.0f), float2( 0.0f, -2.0f), float2( 0.0f,  2.0f),
        float2(-2.0f,  1.0f), float2( 2.0f,  1.0f), float2( 1.0f, -2.0f), float2( 1.0f,  2.0f),
        float2(-2.0f, -1.0f), float2( 2.0f, -1.0f), float2(-1.0f, -2.0f), float2(-1.0f,  2.0f)
    };

    float4 cBase0      = tex2D(_tex0, IN.baseTC.xy);
    half4  cColor0     = cBase0;
    float2 vBestOffset = IN.baseTC.xy;

#ifdef D3D10
    [unroll]
#endif
      int iSampleCount = (GetShaderQuality() > QUALITY_LOW) ? 20 : 8;

    for (int i = 0; i < iSampleCount; i++)
    {
        float2 vLocalOffset = IN.baseTC.xy + Kernel_Neighbors[i] * vPixelOffset.xy;
        half4  cVal0        = tex2D(_tex0, vLocalOffset);

        if (cVal0.a > 0.0f)
        {
            cColor0     = cVal0;
            vBestOffset = vLocalOffset;
        }
    }

    half4 cColor1 = tex2D(_tex0, vBestOffset + vPixelOffset.zw);
    OUT.Color     = cColor0 + cColor1;

    half maxColor0     = max(cColor0.r, max(cColor0.g, cColor0.b));
    half maxOutColor   = max(OUT.Color.r, max(OUT.Color.g, OUT.Color.b));
    half fContribution = maxColor0 / max(maxOutColor, 0.0001f);

    OUT.Color *= vDilateParams.x;

    const half SpriteAlphaRef = 0.1f;

    if (cBase0.a > 0.0f)
    {
        OUT.Color.a = 1.0f - fContribution * (1.0f - SpriteAlphaRef);
    }
    else
    {
        OUT.Color.a = 0.0f;
    }

    return OUT;
}

technique Dilate
{
    pass p0
    {
        VertexShader = compile vs_Auto DilateVS();
        PixelShader  = compile ps_Auto DilatePS();
        CullMode     = None;
    }
}

float4x4 mColorMatrix;

pixout ColorCorrectionPS(vtxOut IN)
{
    pixout OUT;

    half4 screenColor = half4(tex2D(_tex0, IN.baseTC.xy).xyz, 1.0f);

    screenColor.xyz = float3(
        dot(screenColor.xyzw, mColorMatrix[0].xyzw),
        dot(screenColor.xyzw, mColorMatrix[1].xyzw),
        dot(screenColor.xyzw, mColorMatrix[2].xyzw)
    );

    OUT.Color = screenColor;

    return OUT;
}

technique ColorCorrection
{
    pass p0
    {
        VertexShader = compile vs_Auto BaseVS();
        PixelShader  = compile ps_Auto ColorCorrectionPS();
        CullMode     = None;
    }
}

pixout BlurInterpolationPS(vtxOut IN)
{
    pixout OUT;

    half4 screenColor  = tex2D(_tex0, IN.baseTC.xy);
    half4 blurredColor = tex2D(_tex1, IN.baseTC.xy);

    OUT.Color = lerp(blurredColor, screenColor, psParams[0].w);

    return OUT;
}

technique BlurInterpolation
{
    pass p0
    {
        VertexShader = compile vs_Auto BaseVS();
        PixelShader  = compile ps_Auto BlurInterpolationPS();
        CullMode     = None;
    }
}

pixout MaskedBlurInterpolationPS(vtxOut IN)
{
    pixout OUT;

    half4 screenColor  = tex2D(_tex0, IN.baseTC.xy);
    half4 blurredColor = tex2D(_tex1, IN.baseTC.xy);
    half  mask         = sqrt(tex2D(_tex2, IN.baseTC.wz).x);

    OUT.Color = lerp(blurredColor, screenColor, mask * psParams[0].w);

    return OUT;
}

technique MaskedBlurInterpolation
{
    pass p0
    {
        VertexShader = compile vs_Auto BaseVS();
        PixelShader  = compile ps_Auto MaskedBlurInterpolationPS();
        CullMode     = None;
    }
}

float4 vRadialBlurParams;

pixout RadialBlurringPS(vtxOut IN)
{
    pixout OUT;

    float2 vScreenPos   = vRadialBlurParams.xy;
    float2 vBlurVec     = vScreenPos.xy - IN.baseTC.xy;

    float  fInvRadius   = vRadialBlurParams.z;
    float  blurDistSq   = dot(vBlurVec.xy * fInvRadius, vBlurVec.xy * fInvRadius);
    float  blurDist     = saturate(1.0f - blurDistSq);

    float  fBlurWeight  = vRadialBlurParams.w * blurDist * blurDist;

    const int   nSamples = 8;
    const float fWeight  = 0.125f;

    half4 cAccum         = 0.0f;

    for (int i = 0; i < nSamples; i++)
    {
        half4 cCurr  = tex2D(_tex0, IN.baseTC.xy + vBlurVec.xy * (float)i * fBlurWeight);
        cAccum      += cCurr;
    }

    OUT.Color            = cAccum * fWeight;

    return OUT;
}

technique RadialBlurring
{
    pass p0
    {
        VertexShader = compile vs_Auto BaseVS();
        PixelShader  = compile ps_Auto RadialBlurringPS();
        CullMode     = None;
    }
}

struct vtxOutMotionBlurDispl
{
    float4 HPosition     : POSITION;
    float4 tcProj        : TEXCOORDN;
    float4 vVelocity     : TEXCOORDN;
    float4 vVelocityPrev : TEXCOORDN;
};

float4   PI_motionBlurParams;
float4   motionBlurParams;
float4   motionBlurChromaParams;
float4   motionBlurCamParams;
float4x4 mViewProjPrev;
float4   vDirectionalBlur;

sampler2D motionBlurMaskMap : register(s1);

vtxOutMotionBlurDispl MotionBlurDisplVS(vtxIn IN)
{
    vtxOutMotionBlurDispl OUT = (vtxOutMotionBlurDispl)0;

    float4 vPos               = IN.Position;
    vPos.xyz                  = normalize(vPos.xyz) * 25.0f;
    vPos.xyz                 += g_VS_WorldViewPos.xyz;

    OUT.HPosition             = mul(vpMatrix, vPos);

    float4 vNewPos            = OUT.HPosition;
    float4 vPrevPos           = mul(mViewProjPrev, vPos);

    OUT.vVelocity             = HPosToScreenTC(vNewPos);
    OUT.vVelocityPrev         = HPosToScreenTC(vPrevPos);
    OUT.tcProj                = HPosToScreenTC(OUT.HPosition);

    return OUT;
}

pixout MotionBlurdDepthMaskPS(vtxOut IN)
{
    pixout OUT            = (pixout)0;

    float fDepth          = tex2D(depthMapSampler, IN.baseTC).x;
    half  mask_accum      = exp(-fDepth * 50.0f);

    float fRotationAmount = motionBlurParams.w * 5.0f;

    half  fNearestMask    = fDepth * PS_NearFarClipDist.y;
    fNearestMask          = saturate(fNearestMask - 1.0f) * saturate(mask_accum + fRotationAmount);

    OUT.Color.xyz         = tex2D(screenMapSampler, IN.baseTC).xyz;
    OUT.Color.w           = fNearestMask;

    return OUT;
}

pixout MotionBlurDepthMaskHDRPS(vtxOut IN)
{
    pixout OUT            = (pixout)0;

#if D3D10
    // temporary workaround for d3d10 hlsl compiler bug
    OUT.Color  = tex2D(_tex0, IN.baseTC);
    OUT.Color += tex2D(_tex1, IN.baseTC);
#endif

    float fDepth          = tex2D(_tex1, IN.baseTC).x;
    half  mask_accum      = exp(-fDepth * 50.0f);

    float fRotationAmount = motionBlurParams.w * 5.0f;

    half  fNearestMask    = fDepth * PS_NearFarClipDist.y;
    fNearestMask          = saturate(fNearestMask - 1.0f) * saturate(mask_accum + fRotationAmount);

    OUT.Color.xyz         = tex2D(_tex0, IN.baseTC).xyz;
    OUT.Color.w           = fNearestMask;

    return OUT;
}

float2 GetVelocity(sampler2D sVelocity, float2 tc)
{
    float4 cVelocity      = tex2Dlod(sVelocity, float4(tc.xy, 0.0f, 0.0f));
    return cVelocity.xy;
}

pixout MotionBlurObjectPS(vtxOut IN)
{
    pixout OUT            = (pixout)0;
    float4 OriginalUV     = IN.baseTC;

    float2 poisson[8] =
    {
        float2( 0.0f,       0.0f),
        float2( 0.527837f, -0.085868f),
        float2(-0.040088f,  0.536087f),
        float2(-0.670445f, -0.179949f),
        float2(-0.419418f, -0.616039f),
        float2( 0.440453f, -0.639399f),
        float2(-0.757088f,  0.349334f),
        float2( 0.574619f,  0.685879f)
    };

    float4 cOrig               = tex2Dlod(_tex0, float4(IN.baseTC.xy, 0.0f, 0.0f));
    float4 cDummyFetchDx10     = tex2Dlod(_tex1, float4(IN.baseTC.xy, 0.0f, 0.0f)); // WORKAROUND
    float  fOrigDepth          = tex2Dlod(_tex2, float4(IN.baseTC.xy, 0.0f, 0.0f)).x;

    float4 Blurred             = 0.0f;
    float2 pixelVelocity;

    const int NumberOfPostProcessSamples = 8;
    const int nSamples                   = 8;
    int       s                          = 0;

    half fDepthScale = 0.0333f * saturate(mad(1.0f - fOrigDepth, 1.0f - fOrigDepth, 0.0f));

#if D3D10
    [unroll]
#endif
    for (int n = 0; n < nSamples; n++)
    {
        float2 vOffset    = poisson[n] * fDepthScale;
        float  fCurrDepth = tex2Dlod(_tex2, float4(OriginalUV.xy + vOffset, 0.0f, 0.0f)).x;

        if (fCurrDepth > fOrigDepth)
        {
            continue;
        }

        float2 curFramePixelVelocity = GetVelocity(_tex1, OriginalUV.xy + vOffset);
        pixelVelocity.xy             = curFramePixelVelocity;

        half   fLen                  = dot(pixelVelocity.xy, pixelVelocity.xy);

        if (fLen > 0.0f)
        {
#if D3D10
            [unroll]
#endif
            for (float i = 0.0f; i < (float)NumberOfPostProcessSamples; i += 1.0f)
            {
                float2 lookup      = pixelVelocity * ((i * 0.125f) - 0.5f) * PI_motionBlurParams.x + OriginalUV.xy;

                float4 Current     = tex2Dlod(_tex0, float4(lookup.xy, 0.0f, 0.0f));
                float4 curVelocity = tex2Dlod(_tex1, float4(lookup.xy, 0.0f, 0.0f));
                half   fBlend      = length(curVelocity);

                Blurred.xyz       += Current.xyz;
                Blurred.w         += fBlend;
                s++;
            }
        }
    }

    OUT.Color = float4(cOrig.xyz, 1.0f);

    if (s > 0)
    {
        float fLerp   = Blurred.w / (float)s;
        OUT.Color.xyz = lerp(cOrig.xyz, Blurred.xyz / (float)s, saturate(fLerp * 3.0f));
    }

    return OUT;
}

pixout MotionBlurObjectMaskPS(vtxOut IN)
{
    pixout OUT        = (pixout)0.0f;
    float4 OriginalUV = IN.baseTC;

    float2 poisson[7] =
    {
        float2( 0.527837f, -0.085868f),
        float2(-0.040088f,  0.536087f),
        float2(-0.670445f, -0.179949f),
        float2(-0.419418f, -0.616039f),
        float2( 0.440453f, -0.639399f),
        float2(-0.757088f,  0.349334f),
        float2( 0.574619f,  0.685879f)
    };

    half2  cOrigVelocity    = tex2Dlod(_tex0, float4(IN.baseTC.xy, 0.0f, 0.0f)).xy;

    int    nSamples         = 7;
    const half fOffsetRange = 100.0f;

    half2  vOffsetScale     = PS_ScreenSize.zw * fOffsetRange;
    const half fMinVelocityThreshold = 0.0001f;

    half   fCenterVelocity = dot(cOrigVelocity.xy, cOrigVelocity.xy);

    if (fCenterVelocity > 0.0f)
    {
        OUT.Color.x = 1.0f;
        OUT.Color.w = fCenterVelocity > fMinVelocityThreshold ? 1.0f : 0.0f;
        return OUT;
    }
    else
    {
#if D3D10
        [unroll]
#endif
        for (int n = 0; n < nSamples; n++)
        {
            float2 vOffset       = poisson[n] * vOffsetScale;
            float2 pixelVelocity = tex2Dlod(_tex0, float4(OriginalUV.xy + vOffset, 0.0f, 0.0f)).xy;

            half   fLen          = dot(pixelVelocity.xy, pixelVelocity.xy);
            OUT.Color.y         += fLen;
        }

        OUT.Color.y = OUT.Color.y / (float)nSamples;
        OUT.Color.w = OUT.Color.y > fMinVelocityThreshold ? 1.0f : 0.0f;
        OUT.Color.y = OUT.Color.y > 0.0f ? 1.0f : 0.0f;

        return OUT;
    }

    return OUT;
}

pixout MotionBlurObjectUsingMaskPS(vtxOut IN)
{
    pixout OUT;
    float4 OriginalUV = IN.baseTC;

    float2 poisson[7] =
    {
        float2( 0.527837f, -0.085868f),
        float2(-0.040088f,  0.536087f),
        float2(-0.670445f, -0.179949f),
        float2(-0.419418f, -0.616039f),
        float2( 0.440453f, -0.639399f),
        float2(-0.757088f,  0.349334f),
        float2( 0.574619f,  0.685879f)
    };

    float4 cOrig            = tex2Dlod(_tex0, float4(IN.baseTC.xy, 0.0f, 0.0f));
    float4 cDummyFetchDx10  = tex2Dlod(_tex1, float4(IN.baseTC.xy, 0.0f, 0.0f)); // WORKAROUND
    float  fOrigDepth       = tex2Dlod(_tex2, float4(IN.baseTC.xy, 0.0f, 0.0f)).x;
    half4  cMask            = tex2Dlod(_tex3, float4(IN.baseTC.xy, 0.0f, 0.0f));

    OUT.Color = cOrig;

    if (dot(cMask.xy, 1.0f) == 0.0f)
    {
        return OUT;
    }

    float4 Blurred          = 0.0f;
    float2 pixelVelocity;

    const int   nSamples      = 8;
    const int   nSamplesEdges = 7;
    const float nRecipSamples = 0.125f;
    float       s             = 0.0f;

    if (cMask.x > 0.0f)
    {
        pixelVelocity.xy = GetVelocity(_tex1, OriginalUV.xy) * PI_motionBlurParams.x;

#if D3D10
        [unroll]
#endif
        for (float i = 0.0f; i < (float)nSamples; i += 1.0f)
        {
            float2 lookup = pixelVelocity * ((i * nRecipSamples) - 0.5f) + OriginalUV.xy;
            Blurred.xyz  += tex2Dlod(_tex0, float4(lookup.xy, 0.0f, 0.0f)).xyz;
        }

        OUT.Color = half4(Blurred.xyz * nRecipSamples, 1.0f);
        return OUT;
    }
    else
    {
        half fDepthScale = 0.0333f * saturate(mad(1.0f - fOrigDepth, 1.0f - fOrigDepth, 0.0f));

#if D3D10
    [unroll]
#endif
        for (int n = 0; n < nSamplesEdges; n++)
        {
            float2 vOffset       = poisson[n] * fDepthScale;
            float  fCurrDepth    = tex2Dlod(_tex2, float4(OriginalUV.xy + vOffset, 0.0f, 0.0f)).x;

            if (fCurrDepth > fOrigDepth)
            {
                continue;
            }

            float2 curFramePixelVelocity = GetVelocity(_tex1, OriginalUV.xy + vOffset);
            pixelVelocity.xy             = curFramePixelVelocity;

            half   fLen                  = dot(pixelVelocity.xy, pixelVelocity.xy);

            if (fLen > 0.0f)
            {
#if D3D10
    [unroll]
#endif
                for (float i = 0.0f; i < (float)nSamples; i += 1.0f)
                {
                    float2 lookup      = pixelVelocity * ((i * nRecipSamples) - 0.5f) * PI_motionBlurParams.x + OriginalUV.xy;

                    float3 Current     = tex2Dlod(_tex0, float4(lookup.xy, 0.0f, 0.0f)).xyz;
                    float4 curVelocity = tex2Dlod(_tex1, float4(lookup.xy, 0.0f, 0.0f));
                    half   fBlend      = dot(curVelocity, curVelocity);

                    Blurred           += half4(Current.xyz, fBlend);
                }

                s += (float)nSamples;
            }
        }

        if (s > 0.0f)
        {
            half fLerp    = Blurred.w / s;
            OUT.Color.xyz = lerp(cOrig.xyz, Blurred.xyz / s, saturate(fLerp * 3.0f));
        }
    }

    return OUT;
}

pixout OMB_VelocityIDRescalePS(vtxOut IN)
{
    pixout OUT = (pixout)0;

    float2 vScreenSizeRecip = PI_motionBlurParams.zw;

    float4 t0 = tex2D(_tex0, IN.baseTC.xy);
    float4 t1 = tex2D(_tex0, IN.baseTC.xy + float2( 1.0f,  1.0f) * vScreenSizeRecip);
    float4 t2 = tex2D(_tex0, IN.baseTC.xy + float2(-1.0f, -1.0f) * vScreenSizeRecip);
    float4 t3 = tex2D(_tex0, IN.baseTC.xy + float2(-1.0f,  1.0f) * vScreenSizeRecip);
    float4 t4 = tex2D(_tex0, IN.baseTC.xy + float2( 1.0f, -1.0f) * vScreenSizeRecip);

    t0        = (t0.z > t1.z) ? t0 : t1;
    t0        = (t0.z > t2.z) ? t0 : t2;
    t0        = (t0.z > t3.z) ? t0 : t3;
    t0        = (t0.z > t4.z) ? t0 : t4;

    OUT.Color = t0;

    return OUT;
}

float GetResampledOrigDepth(float2 tc)
{
    float2 vScreenSizeRecip = PI_motionBlurParams.xy;

    float t0 = tex2Dlod(_tex1, float4(tc.xy, 0.0f, 0.0f)).x;
    t0       = max(t0, tex2Dlod(_tex1, float4(tc.xy + float2( 1.0f,  1.0f) * vScreenSizeRecip, 0.0f, 0.0f)).x);
    t0       = max(t0, tex2Dlod(_tex1, float4(tc.xy + float2(-1.0f, -1.0f) * vScreenSizeRecip, 0.0f, 0.0f)).x);
    t0       = max(t0, tex2Dlod(_tex1, float4(tc.xy + float2(-1.0f,  1.0f) * vScreenSizeRecip, 0.0f, 0.0f)).x);
    t0       = max(t0, tex2Dlod(_tex1, float4(tc.xy + float2( 1.0f, -1.0f) * vScreenSizeRecip, 0.0f, 0.0f)).x);

    return t0;
}

pixout OMB_OffsetMapPS(vtxOut IN)
{
    pixout OUT = (pixout)0;

    float4 t0 = tex2D(_tex0, IN.baseTC);

    float fLen = length(t0.xy);

    t0.xyz = min(fLen * 100.0f, 1.0f);

    OUT.Color = t0;

    return OUT;
}

pixout OMB_CopyAlphaIDPS(vtxOut IN)
{
    pixout OUT = (pixout)0;

    float4 t0  = tex2D(_tex0, IN.baseTC);
    OUT.Color  = t0;

    return OUT;
}

pixout OMB_VelocityDilationPS(vtxOut IN)
{
    pixout OUT = (pixout)0;

    const int nOffsets = 8;

#if %_RT_SAMPLE1
    float2 vOffsets[nOffsets] =
    {
        float2(-1.0f, 0.0f), float2(1.0f, 0.0f),
        float2(-2.0f, 0.0f), float2(2.0f, 0.0f),
        float2(-3.0f, 0.0f), float2(3.0f, 0.0f),
        float2(-4.0f, 0.0f), float2(4.0f, 0.0f)
    };
#else
    float2 vOffsets[nOffsets] =
    {
        float2(0.0f, -1.0f), float2(0.0f, 1.0f),
        float2(0.0f, -2.0f), float2(0.0f, 2.0f),
        float2(0.0f, -3.0f), float2(0.0f, 3.0f),
        float2(0.0f, -4.0f), float2(0.0f, 4.0f)
    };
#endif

    float2 vScrSizeRecip = PI_motionBlurParams.zw;

    float4 vCenterVelocity = tex2Dlod(_tex0, float4(IN.baseTC.xy, 0.0f, 0.0f));
    float  fCenterDepth    = GetResampledOrigDepth(IN.baseTC.xy);
    float  fOffsetScale    = tex2Dlod(_tex2, float4(IN.baseTC.xy, 0.0f, 0.0f)).x;

    if (fOffsetScale == 0.0f || dot(vCenterVelocity.xy, vCenterVelocity.xy) > 0.0f)
    {
        OUT.Color = vCenterVelocity;
        return OUT;
    }

    float4 Blurred = 0.0f;

#if D3D10
    [unroll]
#endif
    for (int n = 0; n < nOffsets; n++)
    {
        float2 tcLookup             = IN.baseTC.xy + vOffsets[n] * vScrSizeRecip * 2.0f;
        float4 vCurrVelocityDepthID = tex2Dlod(_tex0, float4(tcLookup, 0.0f, 0.0f));

        float  fDepthCmp            = saturate(fCenterDepth - vCurrVelocityDepthID.z);
        fDepthCmp                  *= dot(vCurrVelocityDepthID.xy, vCurrVelocityDepthID.xy);
        fDepthCmp                  *= Blurred.z == 0.0f ? 1.0f : 0.0f;

        if (fDepthCmp > 0.0f)
        {
            Blurred = vCurrVelocityDepthID;
        }
    }

    OUT.Color = Blurred;

    return OUT;
}

pixout OMB_UsingVelocityDilationPS(vtxOut IN)
{
    pixout OUT = (pixout)0;

    float4 OriginalUV    = IN.baseTC;
    float4 cOrig         = tex2Dlod(_tex0, float4(IN.baseTC.xy, 0.0f, 0.0f));
    float4 cOrigVelocity = tex2Dlod(_tex1, float4(IN.baseTC.xy, 0.0f, 0.0f));

    OUT.Color = cOrig;

    if (dot(cOrigVelocity.xy, cOrigVelocity.xy) == 0.0f)
    {
        return OUT;
    }

    float4 Blurred       = 0.0f;
    float2 pixelVelocity = cOrigVelocity.xy;

    const int   nSamples         = 8;
    const float nRecipSamples    = 0.125f;
    const float nRecipSamplesAcc = 1.0f / (float)(nSamples - 1);

    float  fLen = length(pixelVelocity.xy);

    if (fLen > 0.0f)
    {
        pixelVelocity.xy  /= fLen;
    }

    float2 vScrSizeRecip = 1.0f / PS_ScreenSize.xy;
    float2 vMaxRange     = 48.0f * vScrSizeRecip;

    pixelVelocity.xy *= min(fLen, vMaxRange.x) * PI_motionBlurParams.x;

#if D3D10
    [unroll]
#endif
    for (float i = 0.0f; i < (float)nSamples; i += 1.0f)
    {
        float2 lookup = pixelVelocity * ((i * nRecipSamplesAcc) - 0.5f) + OriginalUV.xy;
        float4 tcMB   = tex2Dlod(_tex0, float4(lookup.xy, 0.0f, 0.0f));

        Blurred.xyz += tcMB.xyz;

#if !%_RT_SAMPLE1
        Blurred.w += saturate(100000.0f * tcMB.w);
#else
        Blurred.w += tcMB.w;
#endif
    }

    if (Blurred.w > 0.0f)
    {
        Blurred.xyz *= nRecipSamples;
#if !%_RT_SAMPLE1
        OUT.Color = lerp(cOrig, Blurred, saturate(saturate(Blurred.w * nRecipSamples) * 2.0f + saturate(cOrig.w * 1000.0f)));
#else
        OUT.Color = lerp(cOrig, Blurred, saturate(saturate(Blurred.w * nRecipSamples) * 2.0f));
#endif
    }

    OUT.Color.w = Blurred.w * nRecipSamples;

    return OUT;
}

pixout MotionBlurDisplPS(vtxOutMotionBlurDispl IN)
{
    pixout OUT = (pixout)0;

    int nQuality = GetShaderQuality();

    half4 cMidCurr = tex2Dproj(screenMapSampler, IN.tcProj.xyzw);
    half  fDepth   = tex2Dproj(depthMapSampler, IN.tcProj.xyzw).x * PS_NearFarClipDist.y;

    OUT.Color = cMidCurr;

    float fSamples    = 8.0f;
    float fWeight     = 0.125f;
    float fWeightStep = 0.25f;

    float2 vVelocityPrev = (IN.vVelocityPrev.xy / IN.vVelocityPrev.w) * PI_motionBlurParams.w;
    float2 vVelocity     = (IN.vVelocity.xy / IN.vVelocity.w);
    float2 vVelocityDiv  = vVelocity;

    vVelocity *= PI_motionBlurParams.w;

    float2 vVelocityLerp = vVelocityPrev - vVelocity;

    vVelocityDiv.xy  += vDirectionalBlur.xy * PI_motionBlurParams.w;
    vVelocityLerp.xy += vDirectionalBlur.xy * PI_motionBlurParams.w;

    float4 accum = 0.0f;

#if D3D10
    [unroll]
#endif
    for (float s = -1.0f; s < 1.0f; s += fWeightStep)
    {
        float2 tcFinal   = vVelocityDiv.xy - vVelocityLerp.xy * s;

        if (nQuality == QUALITY_HIGH)
        {
            half fDepthMask = tex2D(screenMapSampler, tcFinal).w;
            tcFinal        += vVelocityLerp.xy * (s - s * fDepthMask);
        }

        accum += tex2D(screenMapSampler, tcFinal);
    }

    accum    *= fWeight;
    OUT.Color = lerp(cMidCurr, accum, saturate(fDepth - 1.0f));

    return OUT;
}

pixout MotionBlurDisplHDRPS(vtxOutMotionBlurDispl IN)
{
    pixout OUT           = (pixout)0;

    int    nQuality      = GetShaderQuality();

    half4  cMidCurr      = tex2Dproj(_tex0, IN.tcProj.xyzw);
    float  fDepth        = tex2Dproj(_tex1, IN.tcProj.xyzw).x * PS_NearFarClipDist.y;

    OUT.Color            = cMidCurr;

#if %_RT_SAMPLE0
    const float fMinDepthMaskThreshold = 0.05f;

    if (cMidCurr.w < fMinDepthMaskThreshold)
    {
        return OUT;
    }
#endif

    if (fDepth - 1.0f <= 0.0f)
    {
        return OUT;
    }

    half2  vVelocityPrev = (IN.vVelocityPrev.xy / IN.vVelocityPrev.w) * PI_motionBlurParams.w;
    half2  vVelocity     = (IN.vVelocity.xy / IN.vVelocity.w);
    half2  vVelocityDiv  = vVelocity;

    vVelocity           *= PI_motionBlurParams.w;

    half2  vVelocityLerp = vVelocityPrev - vVelocity;

    vVelocityDiv.xy  += vDirectionalBlur.xy * PI_motionBlurParams.w;
    vVelocityLerp.xy += vDirectionalBlur.xy * PI_motionBlurParams.w;

    half4  accum    = 0.0f;
    half   fSamples = 8.0f;

#if %_RT_SAMPLE1
    fSamples = 4.0f;
#endif

#if %_RT_SAMPLE0
    const half fWeight     = 1.0f / fSamples;
    const half fWeightStep = 2.0f / fSamples;

#if D3D10
    [unroll]
#endif
    for (half s = -1.0f; s < 1.0f; s += fWeightStep)
    {
        half2 tcFinal = vVelocityDiv.xy - vVelocityLerp.xy * s;
        half4 col     = tex2Dlod(_tex0, float4(tcFinal.xy, 0.0f, 0.0f));
        accum        += lerp(cMidCurr, col, col.w);
    }

    accum    *= fWeight;
    OUT.Color = accum;
#else
    int    scount          = 0;
    const half fWeight     = 1.0f / fSamples;
    const half fWeightStep = 2.0f / fSamples;

#if D3D10
    [unroll]
#endif
    for (half s = -1.0f; s < 1.0f; s += fWeightStep)
    {
        half2 tcFinal    = vVelocityDiv.xy - vVelocityLerp.xy * s;
        half  fDepthMask = tex2Dlod(_tex0, float4(tcFinal.xy, 0.0f, 0.0f)).w;

        if (fDepthMask > 0.0f)
        {
            tcFinal += vVelocityLerp.xy * (s - s * fDepthMask);
            accum   += tex2Dlod(_tex0, float4(tcFinal.xy, 0.0f, 0.0f));
            scount++;
        }
    }

    if (scount > 0)
    {
        accum    /= (half)scount;
        OUT.Color = accum;
    }
#endif

    return OUT;
}

