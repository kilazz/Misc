float4   PI_sunShaftsParams;
float4   sunShaftsParams;
float4x4 SunShafts_ViewProj;
float4   SunShafts_SunPos;

struct vtxOutSunShaftsGen
{
    float4 HPosition : POSITION;
    float2 baseTC    : TEXCOORD0;
    float4 sunPos    : TEXCOORD1;
};

vtxOutSunShaftsGen SunShaftsGenVS(vtxIn IN)
{
    vtxOutSunShaftsGen OUT = (vtxOutSunShaftsGen)0;

    float4 vPos    = IN.Position;
    OUT.HPosition  = mul(vpMatrix, vPos);

    OUT.baseTC.xy  = IN.baseTC.xy;

    float4 SunPosH = mul(SunShafts_ViewProj, SunShafts_SunPos);
    OUT.sunPos.x   = (SunPosH.x + SunPosH.w) * 0.5f;
    OUT.sunPos.y   = (-SunPosH.y + SunPosH.w) * 0.5f;
    OUT.sunPos.z   = SunPosH.w;

    OUT.sunPos.w   = dot(normalize(SunShafts_SunPos).xyz, SunShafts_ViewProj[2].xyz);

    return OUT;
}

pixout SunShaftsMaskGenPS(vtxOutTexToTex IN)
{
    pixout OUT;

    int    nQuality   = GetShaderQuality();

    half4  scene      = 0.0f;
    half   sceneDepth = 0.0f;

    if (nQuality == QUALITY_HIGH)
    {
        half sceneDepth0 = tex2D(_tex0, IN.baseTC0.xy).r;
        half sceneDepth1 = tex2D(_tex0, IN.baseTC1.xy).r;
        half sceneDepth2 = tex2D(_tex0, IN.baseTC2.xy).r;
        half sceneDepth3 = tex2D(_tex0, IN.baseTC3.xy).r;
        half sceneDepth4 = tex2D(_tex0, IN.baseTC4.xy).r;
        sceneDepth       = (sceneDepth0 + sceneDepth1 + sceneDepth2 + sceneDepth3 + sceneDepth4) * 0.2f;

        half4 scene0     = tex2D(_tex1, IN.baseTC0.xy);
        half4 scene1     = tex2D(_tex1, IN.baseTC1.xy);
        half4 scene2     = tex2D(_tex1, IN.baseTC2.xy);
        half4 scene3     = tex2D(_tex1, IN.baseTC3.xy);
        half4 scene4     = tex2D(_tex1, IN.baseTC4.xy);
        scene            = (scene0 + scene1 + scene2 + scene3 + scene4) * 0.2f;
    }
    else
    {
        sceneDepth = tex2D(_tex0, IN.baseTC0.xy).r;
        scene      = tex2D(_tex1, IN.baseTC0.xy);
    }

    half fShaftsMask = 1.0f - sceneDepth;

    OUT.Color = half4(scene.xyz * saturate(sceneDepth), fShaftsMask);

    return OUT;
}

pixout SunShaftsGenPS(vtxOutSunShaftsGen IN)
{
    pixout OUT;

    float2 sunPosProj   = IN.sunPos.xy / IN.sunPos.z;
    float  fSign        = IN.sunPos.w;

    float2 sunVec       = sunPosProj.xy - IN.baseTC.xy;
    float  fAspectRatio = 1.333f * PS_ScreenSize.y / PS_ScreenSize.x;

    float  sunDist      = saturate(fSign) * saturate(1.0f - saturate(length(sunVec * float2(1.0f, fAspectRatio)) * PI_sunShaftsParams.y));
    float2 sunDir       = sunPosProj.xy - IN.baseTC.xy;

    half4  accum        = 0.0f;
    sunDir.xy          *= PI_sunShaftsParams.x * fSign;

#if D3D10
    [unroll]
#endif
    for (int i = 0; i < 8; i++)
    {
        half4 depth  = tex2D(_tex0, IN.baseTC.xy + sunDir.xy * (float)i);
        accum       += depth * (1.0f - (float)i * 0.125f);
    }

    accum *= 0.125f;

    OUT.Color    = accum * 2.0f * float4(sunDist.xxx, 1.0f);
    OUT.Color.w += 1.0f - saturate(saturate(fSign * 0.1f + 0.9f));

    return OUT;
}

float4 blendSoftLight(float4 a, float4 b)
{
    float4 c = 2.0f * a * b + a * a * (1.0f - 2.0f * b);
    float4 d = sqrt(a) * (2.0f * b - 1.0f) + 2.0f * a * (1.0f - b);

    float4 res;
    res.x = (b.x < 0.5f) ? c.x : d.x;
    res.y = (b.y < 0.5f) ? c.y : d.y;
    res.z = (b.z < 0.5f) ? c.z : d.z;
    res.w = (b.w < 0.5f) ? c.w : d.w;

    return res;
}

pixout SunShaftsDisplayPS(vtxOut IN)
{
    pixout OUT;

    half4 cScreen     = tex2D(_tex0, IN.baseTC.xy);
    half4 cSunShafts  = tex2D(_tex1, IN.baseTC.xy);

    half  fShaftsMask = saturate(1.00001f - cSunShafts.w) * sunShaftsParams.x * 2.0f;

    float4 sunColor   = 1.0f;
    sunColor.xyz      = normalize(g_PS_SunColor.xyz);

    OUT.Color         = cScreen + cSunShafts.xyzz * sunShaftsParams.y * sunColor * (1.0f - cScreen);
    OUT.Color         = blendSoftLight(OUT.Color, sunColor * fShaftsMask * 0.5f + 0.5f);

    return OUT;
}

technique SunShaftsMaskGen
{
    pass p0
    {
        VertexShader = compile vs_Auto TexToTexVS();
        PixelShader  = compile ps_Auto SunShaftsMaskGenPS();
        CullMode     = None;
    }
}

technique SunShaftsGen
{
    pass p0
    {
        VertexShader = compile vs_Auto SunShaftsGenVS();
        PixelShader  = compile ps_Auto SunShaftsGenPS();
        CullMode     = None;
    }
}

technique SunShaftsDisplay
{
    pass p0
    {
        VertexShader = compile vs_Auto BaseVS();
        PixelShader  = compile ps_Auto SunShaftsDisplayPS();
        CullMode     = None;
    }
}

float4 vDepthEnhancementParams;

pixout DepthEnhancementPS(vtxOut IN)
{
    pixout OUT;

    half4 cScreen = tex2D(_tex0, IN.baseTC.xy);

    float2 vSamples[8] =
    {
        float2( 0.0f, -1.0f),
        float2(-1.0f,  0.0f),
        float2( 0.0f,  1.0f),
        float2( 1.0f,  0.0f),
        float2( 0.5f,  0.85f),
        float2( 0.85f, 0.5f),
        float2(-0.5f,  0.85f),
        float2(-0.85f, 0.5f)
    };

    float fDepth     = tex2D(_tex1, IN.baseTC.xy).x * PS_NearFarClipDist.y;
    float fDepthBlur = 0.0f;

    for (int i = 0; i < 8; i++)
    {
        float sampleDepth = tex2D(_tex1, IN.baseTC.xy + 2.0f * vSamples[i] / ScrSize.xy).x * PS_NearFarClipDist.y;
        fDepthBlur       += clamp(fDepth - sampleDepth, -1.0f, 1.0f);
    }

    fDepthBlur *= 0.125f;

    OUT.Color = saturate(1.0f - abs(fDepthBlur)) * cScreen;

    return OUT;
}

technique DepthEnhancement
{
    pass p0
    {
        VertexShader = compile vs_Auto BaseVS();
        PixelShader  = compile ps_Auto DepthEnhancementPS();
        CullMode     = None;
    }
}

pixout ChromaShiftPS(vtxOut IN)
{
    pixout OUT;

    half4 cScreen = 0.0f;

    cScreen.x = tex2D(_tex0, (IN.baseTC.xy - 0.5f) * (1.0f - psParams[0].x) + 0.5f).x;
    cScreen.y = tex2D(_tex0, (IN.baseTC.xy - 0.5f) * (1.0f - psParams[0].y) + 0.5f).y;
    cScreen.z = tex2D(_tex0, (IN.baseTC.xy - 0.5f) * (1.0f - psParams[0].z) + 0.5f).z;

    OUT.Color = cScreen;

    return OUT;
}

technique ChromaShift
{
    pass p0
    {
        VertexShader = compile vs_Auto BaseVS();
        PixelShader  = compile ps_Auto ChromaShiftPS();
        CullMode     = None;
    }
}

sampler2D underwaterBumpSampler = sampler_state
{
    Texture   = textures/defaults/screen_noisy_bump.dds;
    MinFilter = LINEAR;
    MagFilter = LINEAR;
    MipFilter = LINEAR;
    AddressU  = Wrap;
    AddressV  = Wrap;
};

pixout UnderwaterViewPS(vtxOut IN)
{
    pixout OUT;

#if D3D10
    // temporary workaround for d3d10 hlsl compiler bug
    OUT.Color = tex2D(screenMapSampler, IN.baseTC.xy);
#endif

    float  anim      = frac(AnimGenParams * 0.01f);

    half4  cBumpy    = mad(tex2D(underwaterBumpSampler, IN.baseTC.xy * 0.025f + anim), 2.0f, -1.0f);
    cBumpy          += mad(tex2D(underwaterBumpSampler, IN.baseTC.yx * 0.033f - anim), 2.0f, -1.0f);
    cBumpy.xyz       = normalize(cBumpy.xyz);

    half4  cScreen   = tex2D(screenMapSampler, IN.baseTC.xy + cBumpy.xy * 0.01f);

    OUT.Color        = cScreen;

    return OUT;
}

technique UnderwaterView
{
    pass p0
    {
        VertexShader = compile vs_Auto BaseVS();
        PixelShader  = compile ps_Auto UnderwaterViewPS();
        CullMode     = None;
    }
}

float4x4 vpGodMatrix         : PI_Composite;
float4x4 vpGodMatrixI        : PB_UnProjMatrix;

float4   CausticsAmbient     : PI_Ambient;
float4   CausticParams       : PB_CausticsParams;

float4   PI_GodRaysParamsVS;
float4   PI_GodRaysParamsPS;
float4   PI_GodRaysSunDirVS;
float4   CausticSmoothSunDir : PB_CausticsSmoothSunDirection;

sampler2D wavesSampler = sampler_state
{
    Texture   = textures/defaults/oceanwaves_ddn.dds;
    MinFilter = LINEAR;
    MagFilter = LINEAR;
    MipFilter = LINEAR;
    AddressU  = Wrap;
    AddressV  = Wrap;
};

sampler2D causticsSampler = sampler_state
{
    Texture   = textures/defaults/caustics_sampler.dds;
    MinFilter = LINEAR;
    MagFilter = LINEAR;
    MipFilter = NONE;
    AddressU  = Clamp;
    AddressV  = Clamp;
};

float g_fWaterLevel
<
    Position;
> = {PB_WaterLevel};

struct vtxOutGodRays
{
    float4 HPosition  : POSITION;
    float4 baseTC     : TEXCOORDN;
    float4 waveTC     : TEXCOORDN;
    float4 causticTC0 : TEXCOORDN;
    float4 causticTC1 : TEXCOORDN;
    float4 vPosition  : TEXCOORDN;
};

vtxOutGodRays UnderwaterGodRaysVS(vtxIn IN)
{
    vtxOutGodRays OUT = (vtxOutGodRays)0;

    float4 vPos = IN.Position;
    vPos.xy     = vPos.xy * 2.0f - 1.0f;
    vPos.xy    *= 1.2f;

    vPos.z = 0.1f + 0.88f * saturate(PI_GodRaysParamsVS.z * PI_GodRaysParamsVS.w);
    vPos.w = 1.0f;

    vPos  = mul(vpGodMatrixI, vPos);
    vPos /= vPos.w;

    OUT.HPosition = mul(vpGodMatrix, vPos);

    OUT.baseTC.xy = IN.baseTC.xy;
    OUT.baseTC.y  = 1.0f - OUT.baseTC.y;

    OUT.vPosition.xyz = vPos.xyz;
    OUT.vPosition.w   = 1.0f;

    float3 dirZ = CausticSmoothSunDir.xyz;
    float3 up   = float3(0.0f, 0.0f, 1.0f);
    float3 dirX = normalize(cross(up, dirZ));
    float3 dirY = normalize(cross(dirZ, dirX));

    float3x3 mLightView;
    mLightView[0] = dirX.xyz;
    mLightView[1] = dirY.xyz;
    mLightView[2] = dirZ.xyz;

    float2 uv         = mul(mLightView, OUT.vPosition.xyz).xy * 0.5f;

    OUT.waveTC.xy     = mad(uv, 0.00024f, g_VS_AnimGenParams.w * 0.06f);
    OUT.waveTC.wz     = mad(uv, 0.0002f, g_VS_AnimGenParams.w * 0.05f);

    OUT.causticTC0.xy = mad(uv, 0.01f, g_VS_AnimGenParams.w * 0.1f);
    OUT.causticTC0.wz = mad(uv.yx, 0.01f, -g_VS_AnimGenParams.w * 0.11f);

    OUT.causticTC1.xy = mad(uv, 0.04f, g_VS_AnimGenParams.w * 0.1f);
    OUT.causticTC1.wz = mad(uv.yx, 0.04f, -g_VS_AnimGenParams.w * 0.11f);

    return OUT;
}

pixout UnderwaterGodRaysPS(vtxOutGodRays IN)
{
    pixout OUT;

#if D3D10
    // temporary workaround for d3d10 hlsl compiler bug
    OUT.Color = tex2D(screenMapSampler, IN.baseTC.xy);
#endif

    float3 wave = 0.0f;
    wave.xy     = FetchNormalMap(wavesSampler, IN.waveTC.xy).xy;
    wave.xy    += FetchNormalMap(wavesSampler, IN.waveTC.wz).xy;

    wave.xy = wave.xy - 1.0f;
    wave.z  = sqrt(1.0f - dot(wave.xy, wave.xy));
    wave   *= 0.02f;

    half3 causticMapR = 0.0f;
    causticMapR.xy     = FetchNormalMap(wavesSampler, IN.causticTC0.xy + wave.xy).xy;
    causticMapR.xy    += FetchNormalMap(wavesSampler, IN.causticTC0.wz + wave.xy).xy;

    causticMapR.xy = causticMapR.xy - 1.0f;
    causticMapR.z  = sqrt(1.0f - dot(causticMapR.xy, causticMapR.xy));

    half2 causticHighFreq = 0.0f;
    causticHighFreq  = FetchNormalMap(wavesSampler, IN.causticTC1.xy + wave.xy).xy;
    causticHighFreq += FetchNormalMap(wavesSampler, IN.causticTC1.wz + wave.xy).xy;
    causticHighFreq  = mad(causticHighFreq, 2.0f, -2.0f);

    causticMapR.xy += causticHighFreq;

    half3 cCaustic;
    cCaustic.x = tex2D(causticsSampler, mad(causticMapR.xy, 0.55f, 0.55f)).x;
    cCaustic.y = tex2D(causticsSampler, mad(causticMapR.xy, 0.525f, 0.525f)).x;
    cCaustic.z = tex2D(causticsSampler, mad(causticMapR.xy, 0.5f, 0.5f)).x;

    float slice_pos = PI_GodRaysParamsPS.z * PI_GodRaysParamsPS.w;

    cCaustic *= cCaustic;

    half fHighlightAtten = 1.0f;
    half fAtten          = 1.0f;

    cCaustic += pow(cCaustic, 8.0f);

    half4 cScreen = tex2D(screenMapSampler, IN.baseTC.xy);
    cScreen.xyz   = cCaustic * PI_GodRaysParamsPS.w * PI_GodRaysParamsPS.y * saturate(CausticParams.y) * 0.25f;

    fAtten      *= slice_pos;
    cScreen.xyz *= fAtten * fHighlightAtten;

    OUT.Color = cScreen;

    return OUT;
}

pixout UnderwaterGodRaysFinalPS(vtxOut IN)
{
    pixout OUT;

    float anim = frac(AnimGenParams * 0.01f);

    half4 cBumpy = mad(tex2D(underwaterBumpSampler, IN.baseTC.xy * 0.025f + anim), 2.0f, -1.0f);
    cBumpy      += mad(tex2D(underwaterBumpSampler, IN.baseTC.yx * 0.033f - anim), 2.0f, -1.0f);
    cBumpy.xyz   = normalize(cBumpy.xyz);

    half4 cScreen   = tex2D(screenMapSampler, IN.baseTC.xy + cBumpy.xy * 0.0125f);
    half4 cCaustics = tex2D(screenMapScaledSampler_d4, IN.baseTC.xy + cBumpy.xy * 0.01f);

    OUT.Color = cScreen + cCaustics;

    return OUT;
}

technique UnderwaterGodRays
{
    pass p0
    {
        VertexShader = compile vs_Auto UnderwaterGodRaysVS();
        PixelShader  = compile ps_Auto UnderwaterGodRaysPS();
        CullMode     = None;
    }
}

technique UnderwaterGodRaysFinal
{
    pass p0
    {
        VertexShader = compile vs_Auto BaseVS();
        PixelShader  = compile ps_Auto UnderwaterGodRaysFinalPS();
        CullMode     = None;
    }
}

float4 PI_volScatterParamsVS;
float4 PI_volScatterParamsPS;
float4 VolumetricScattering;
float4 VolumetricScatteringColor;

sampler3D volumeMapSampler = sampler_state
{
    Texture   = textures/defaults/Noise3D.dds;
    MinFilter = LINEAR;
    MagFilter = LINEAR;
    MipFilter = LINEAR;
    AddressU  = Wrap;
    AddressV  = Wrap;
    AddressW  = Wrap;
};

struct vtxOutVolumetricScattering
{
    float4 HPosition  : POSITION;
    float4 baseTC     : TEXCOORDN;
    float4 vPosition0 : TEXCOORDN;
    float4 vPosition1 : TEXCOORDN;
};

vtxOutVolumetricScattering VolumetricScatteringVS(vtxIn IN)
{
    vtxOutVolumetricScattering OUT = (vtxOutVolumetricScattering)0;

    float4 vPos = IN.Position;
    vPos.xy     = vPos.xy * 2.0f + g_VS_ScreenSize.zw - 1.0f;

    vPos.z = 0.5f + 0.5f * saturate(PI_volScatterParamsVS.z * PI_volScatterParamsVS.w);
    vPos.w = 1.0f;

    vPos  = mul(vpGodMatrixI, vPos);
    vPos /= vPos.w;

    OUT.HPosition = mul(vpGodMatrix, vPos);

    OUT.baseTC.xy = IN.baseTC.xy;
    OUT.baseTC.y  = 1.0f - OUT.baseTC.y;

    vPos *= VolumetricScattering.x;

    float animGen = g_VS_AnimGenParams.w * VolumetricScattering.y;

    OUT.vPosition0.xyz = vPos.xyz * 0.1f + animGen * 0.2f;
    OUT.vPosition1.xyz = vPos.xyz * 0.11f - animGen * 0.3f;

    return OUT;
}

pixout VolumetricScatteringPS(vtxOutVolumetricScattering IN)
{
    pixout OUT;

    float fVolume  = 1.0f - abs(mad(tex3D(volumeMapSampler, IN.vPosition0).w, 2.0f, -1.0f));
    fVolume       += 1.0f - abs(mad(tex3D(volumeMapSampler, IN.vPosition1).w, 2.0f, -1.0f));
    fVolume       *= 0.5f;

    fVolume = fVolume * fVolume;
    fVolume = fVolume * fVolume;
    fVolume = fVolume * fVolume;

    OUT.Color = fVolume * PI_volScatterParamsPS.w * PI_volScatterParamsPS.y * CausticParams.y * VolumetricScatteringColor;

    return OUT;
}

pixout VolumetricScatteringFinalPS(vtxOut IN)
{
    pixout OUT;

    half4 cScreen = tex2D(screenMapSampler, IN.baseTC.xy);
    half4 cVolume = tex2D(screenMapScaledSampler_d4, IN.baseTC.xy);

    OUT.Color     = cScreen + cVolume;

    return OUT;
}

technique VolumetricScattering
{
    pass p0
    {
        VertexShader = compile vs_Auto VolumetricScatteringVS();
        PixelShader  = compile ps_Auto VolumetricScatteringPS();
        CullMode     = None;
    }
}

technique VolumetricScatteringFinal
{
    pass p0
    {
        VertexShader = compile vs_Auto BaseVS();
        PixelShader  = compile ps_Auto VolumetricScatteringFinalPS();
        CullMode     = None;
    }
}

float4x4 mComposite  : PI_Composite;
float4x4 mUnproject  : PB_UnProjMatrix;
float4   cRainColor;
float4   PI_RainParamsVS;
float4   PI_RainParamsPS;

struct vtxOutDistantRain
{
    float4 HPosition  : POSITION;
    float4 vPosition  : TEXCOORDN;
    float4 vPosition2 : TEXCOORDN;
    float4 tcProj     : TEXCOORDN;
};

vtxOutDistantRain DistantRainVS(vtxIn IN)
{
    vtxOutDistantRain OUT = (vtxOutDistantRain)0;

    float4 vPos = IN.Position;
    vPos.xy     = vPos.xy * 2.0f - 1.0f;
    vPos.xy    *= 1.2f;

    vPos.z = 0.005f + 0.99f + 0.0025f * saturate(PI_RainParamsVS.z * PI_RainParamsVS.w);
    vPos.w = 1.0f;

    vPos   = mul(mUnproject, vPos);
    vPos  /= vPos.w;
    vPos.w = 1.0f;

    OUT.HPosition = mul(mComposite, vPos);

    OUT.tcProj = HPosToScreenTC(OUT.HPosition);

    float  animOffset1 = 100.0f * g_VS_AnimGenParams.x * (PI_RainParamsVS.w * 0.5f + 0.5f);
    float  animOffset2 = 500.0f * g_VS_AnimGenParams.x * (PI_RainParamsVS.w * 0.5f + 0.5f);

    OUT.vPosition.xyz  = vPos.xyz + PI_RainParamsVS.x * float3(0.0f, 0.0f, animOffset1);
    OUT.vPosition2.xyz = vPos.xyz + PI_RainParamsVS.x * float3(0.0f, 0.0f, animOffset2);

    OUT.vPosition.w  = vPos.z;
    OUT.vPosition2.w = 1.0f;

    return OUT;
}

pixout DistantRainPS(vtxOutDistantRain IN)
{
    pixout OUT;

#if D3D10
#endif

    float3 pos1           = IN.vPosition.xyz * 0.45f * float3(1.0f, 1.0f, 0.05f) * 0.1f;
    float3 pos2           = IN.vPosition.xyz * 0.3f * float3(1.1f, 2.09f, 0.34f) * 0.1f;
    float3 pos3           = IN.vPosition2.xyz * 0.245f * float3(1.0f, 1.0f, 0.1f) * 0.0005f;

    OUT.Color             = saturate(tex3D(volumeMapSampler, pos1).w) * 0.1f;
    OUT.Color            += saturate(mad(tex3D(volumeMapSampler, pos2).w, 2.0f, -0.8f)) * 0.05f;

    half   fHitMask       = OUT.Color.x;

    OUT.Color            *= 0.5f;
    OUT.Color            *= saturate(mad(tex3D(volumeMapSampler, pos3).w, 0.5f, 0.5f));

    float2 projTC         = IN.tcProj.xy / IN.tcProj.w;

    half   fSceneDepth    = tex2D(depthMapSampler, projTC).x;
    fSceneDepth          += tex2D(depthMapSampler, projTC + texToTexParams0.xy).x;
    fSceneDepth          += tex2D(depthMapSampler, projTC + texToTexParams0.zw).x;
    fSceneDepth          += tex2D(depthMapSampler, projTC + texToTexParams1.xy).x;
    fSceneDepth          += tex2D(depthMapSampler, projTC + texToTexParams1.zw).x;
    fSceneDepth          *= PS_NearFarClipDist.y * 0.2f;

    float  fRainDepth     = IN.tcProj.w;

    half   softIntersect  = saturate(0.25f * (fSceneDepth - fRainDepth));
    float  fWaterSoftIsec = saturate(0.25f * (IN.vPosition.w - g_fWaterLevel));

    half   fGroundHit     = (1.0f - saturate(0.05f * (fSceneDepth - fRainDepth))) * 0.5f;
    half   fWaterHit      = 1.0f - saturate(0.5f * (IN.vPosition.w - g_fWaterLevel));

    fGroundHit           += fWaterHit;

    fHitMask              = saturate(mad(saturate(fHitMask), 4.0f, -0.2f));
    fGroundHit           *= fHitMask;

    OUT.Color            += fGroundHit;
    OUT.Color            *= (1.0f - PI_RainParamsPS.w) * 0.5f * softIntersect * fWaterSoftIsec * PI_RainParamsPS.y * cRainColor;

    return OUT;
}

pixout DistantRainFinalPS(vtxOut IN)
{
    pixout OUT;

    half4 cScreen = tex2D(screenMapSampler, IN.baseTC.xy);
    half4 cRain   = tex2D(screenMapScaledSampler_d2, IN.baseTC.xy);

    OUT.Color     = cScreen + cRain;

    return OUT;
}

technique DistantRain
{
    pass p0
    {
        VertexShader = compile vs_Auto DistantRainVS();
        PixelShader  = compile ps_Auto DistantRainPS();
        CullMode     = None;
    }
}

technique DistantRainFinal
{
    pass p0
    {
        VertexShader = compile vs_Auto BaseVS();
        PixelShader  = compile ps_Auto DistantRainFinalPS();
        CullMode     = None;
    }
}

float4 waterPuddlesParams;

struct vtxOutWaterPuddles
{
    float4 HPosition : POSITION;
    float2 baseTC    : TEXCOORDN;
    float4 noiseTC   : TEXCOORDN;
};

vtxOutWaterPuddles waterPuddlesVS(vtxIn IN)
{
    vtxOutWaterPuddles OUT = (vtxOutWaterPuddles)0;

    float4 vPos   = IN.Position;
    OUT.HPosition = mul(vpMatrix, vPos);
    OUT.baseTC.xy = IN.baseTC.xy;

    return OUT;
}

float gaussian(float d2, float radius)
{
    return exp(-d2 / radius);
}

pixout waterPuddlesPS(vtxOutWaterPuddles IN)
{
    pixout OUT;

    float2 vDropPos = mad(waterPuddlesParams.xy, 2.0f, -1.0f);

    float2 offsets[4] =
    {
        float2( 1.0f,  0.0f),
        float2(-1.0f,  0.0f),
        float2( 0.0f,  1.0f),
        float2( 0.0f, -1.0f)
    };

    float4 c            = tex2D(_tex0, IN.baseTC).x;
    float4 d            = tex2D(_tex1, IN.baseTC).x;

    float  fDilateRatio = 1.0f;
    float  fSpeedFactor = 0.33f;
    float  fPixSize     = 1.0f / 256.0f;
    float  fDamping     = 0.999f;

    float  offsetScale  = fDilateRatio * fPixSize;

    float4 l            = tex2D(_tex0, IN.baseTC + offsetScale * offsets[0]).x;
    float4 r            = tex2D(_tex0, IN.baseTC + offsetScale * offsets[1]).x;
    float4 t            = tex2D(_tex0, IN.baseTC + offsetScale * offsets[2]).x;
    float4 b            = tex2D(_tex0, IN.baseTC + offsetScale * offsets[3]).x;

    float  fA           = fSpeedFactor;
    float  fB           = 2.0f - 4.0f * fSpeedFactor;

    float  sum          = (r.x + l.x + t.x + b.x) * fA + fB * c.x - d.x;

    OUT.Color           = float4(sum.xxx, 1.0f) * fDamping;

    float  dropDist     = length(abs(mad(frac(IN.baseTC.xy - vDropPos), 2.0f, -1.0f)));
    OUT.Color          += waterPuddlesParams.w * gaussian(dropDist, 2.0f / 256.0f);

    return OUT;
}

pixout waterPuddlesDisplayPS(vtxOut IN)
{
    pixout OUT;

    float3 vWeights = 0.0f;

    vWeights.x     = tex2D(_tex0, IN.baseTC.xy).x;
    vWeights.y     = tex2D(_tex0, IN.baseTC.xy + float2(1.0f, 0.0f) / waterPuddlesParams.w).x;
    vWeights.z     = tex2D(_tex0, IN.baseTC.xy + float2(0.0f, 1.0f) / waterPuddlesParams.w).x;

    vWeights       = mad(vWeights, 2.0f, -1.0f);

    float3 vNormal = float3(vWeights.x - vWeights.y, vWeights.x - vWeights.z, 1.0f);
    vNormal        = normalize(vNormal);

    OUT.Color.xyz  = mad(vNormal, 0.5f, 0.5f);
    OUT.Color.w    = mad(vWeights.x, 0.5f, 0.5f);

    return OUT;
}

technique WaterPuddlesGen
{
    pass p0
    {
        VertexShader = compile vs_Auto waterPuddlesVS();
        PixelShader  = compile ps_Auto waterPuddlesPS();
        CullMode     = None;
    }
}

technique WaterPuddlesDisplay
{
    pass p0
    {
        VertexShader = compile vs_Auto BaseVS();
        PixelShader  = compile ps_Auto waterPuddlesDisplayPS();
        CullMode     = None;
    }
}

#if %DYN_BRANCHING_POSTPROCESS

pixout FilrateProfilePS(vtxOut IN)
{
    pixout OUT;

    const int nSamples      = 32;
    float     fRecipSamples = 1.0f / (float)nSamples;

    half4     acc           = 0.0f;

#if D3D10
    [unroll]
#endif
    for (int n = 0; n < nSamples; n++)
    {
        acc += tex2D(_tex0, IN.baseTC.xy) + mad(frac((float)n * fRecipSamples * 10.0f), 2.0f, -1.0f) * 4.0f;
    }

    OUT.Color = acc * fRecipSamples;

    return OUT;
}

technique FillrateProfile
{
    pass p0
    {
        VertexShader = compile vs_3_0 BaseVS();
        PixelShader  = compile ps_3_0 FilrateProfilePS();
        CullMode     = None;
    }
}

#endif

sampler2D grainNoiseSampler = sampler_state
{
    Texture   = textures/defaults/vector_noise.dds;
    MinFilter = POINT;
    MagFilter = POINT;
    MipFilter = POINT;
    AddressU  = Wrap;
    AddressV  = Wrap;
};

pixout GrainFilterPS(vtxOut IN)
{
    pixout OUT;

    float2 vNoiseTC = mad(IN.baseTC.xy, (PS_ScreenSize.xy / 64.0f), (psParams[0].xy / PS_ScreenSize.xy));
    float2 vNoise   = tex2D(grainNoiseSampler, vNoiseTC).xy + dot(IN.baseTC.xy, 1.0f) * 65535.0f;

    vNoise = frac(vNoise);
    vNoise = mad(vNoise, 2.0f, -1.0f);

    half4 cScreen = tex2D(screenMapSampler, IN.baseTC);

    OUT.Color = cScreen + dot(vNoise.xy, 0.5f) * psParams[0].w;

    return OUT;
}

technique GrainFilter
{
    pass p0
    {
        VertexShader = compile vs_Auto BaseVS();
        PixelShader  = compile ps_Auto GrainFilterPS();
        CullMode     = None;
    }
}
