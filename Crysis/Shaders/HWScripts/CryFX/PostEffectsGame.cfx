sampler2D grainNoiseSampler = sampler_state
{
  Texture     = textures/defaults/vector_noise.dds;
  MinFilter   = POINT;
  MagFilter   = POINT;
  MipFilter   = POINT;
  AddressU    = Wrap;
  AddressV    = Wrap;
};

pixout StylizedFilterPS(vtxOut IN)
{
  pixout OUT = (pixout)1;

  float2 vNoiseTC = (IN.baseTC.xy) * (PS_ScreenSize.xy / 64.0f) + (psParams[0].xy / PS_ScreenSize.xy);
  float2 vNoise   = tex2D(grainNoiseSampler, vNoiseTC) + dot(IN.baseTC.xy, 1.0f) * 65535.0f;
  vNoise          = frac(vNoise) * 2.0f - 1.0f;

  half4 cScreen     = tex2D(screenMapSampler, IN.baseTC);
  half4 cScreenBlur = tex2D(screenMapScaledSampler_d2, IN.baseTC);
  cScreen           = lerp(cScreenBlur, cScreen, 2.0f);

  float lum = dot(cScreen, float3(0.33f, 0.59f, 0.11f));

  float xWhite = 1.0f - length(cScreenBlur - float3(1.0f, 1.0f, 1.0f));
  float3 reds  = max(float3(xWhite * 1.5f, xWhite * 0.75f, xWhite * 0.25f) - 0.25f, 0.0f);

  float xRed = 1.0f - length(cScreenBlur - float3(1.0f, 0.0f, 0.0f));
  reds      += max(float3(xRed, 0.0f, 0.0f) - 0.25f, 0.0f);

  OUT.Color.xyz = lum + reds;
  OUT.Color    += dot(vNoise.xy, 0.5f) * 0.1f;

  return OUT;
}

technique StylizedFilter
{
  pass p0
  {
    VertexShader = compile vs_Auto BaseVS();
    PixelShader  = compile ps_Auto StylizedFilterPS();
    CullMode     = None;
  }
}

struct vtxOutBinocularView
{
  float4 HPosition : POSITION;
  float4 baseTC0   : TEXCOORD0;
  float4 baseTC1   : TEXCOORD1;
  float4 baseTC2   : TEXCOORD2;
  float4 baseTC3   : TEXCOORD3;
};

vtxOutBinocularView BinocularViewVS(vtxIn IN)
{
  vtxOutBinocularView OUT = (vtxOutBinocularView)0;

  float2 sSize = ScrSize.zw;
  OUT.HPosition = mul(vpMatrix, IN.Position);
  OUT.baseTC0.xy = IN.baseTC.xy;
  OUT.baseTC1.xy = IN.baseTC.xy + 3.0f * float2(0.0f, -1.0f) * sSize;
  OUT.baseTC2.xy = IN.baseTC.xy + 3.0f * float2(-1.0f, 1.0f) * sSize;
  OUT.baseTC3.xy = IN.baseTC.xy + 3.0f * float2(1.0f, 1.0f) * sSize;

  return OUT;
}

pixout BinocularViewPS(vtxOutBinocularView IN)
{
  pixout OUT = (pixout)1;

  half4 c  = tex2D(_tex0, IN.baseTC0);
  half4 c0 = tex2D(_tex0, IN.baseTC1);
  half4 c1 = tex2D(_tex0, IN.baseTC2);
  half4 c2 = tex2D(_tex0, IN.baseTC3);

  half3 edges;
  edges.x = abs(c.w - c0.w);
  edges.y = abs(c.w - c1.w);
  edges.z = abs(c.w - c2.w);
  edges   = (edges > 0.0f);

  half fSilhouete = dot(edges.xyz, 1.333f);

  float d  = tex2D(_tex1, IN.baseTC0).x;
  float d0 = tex2D(_tex1, IN.baseTC1).x;
  float d1 = tex2D(_tex1, IN.baseTC2).x;
  float d2 = tex2D(_tex1, IN.baseTC3).x;

  float3 cSilhoueteMask = float3(d0 < d, d1 < d, d2 < d);

  half4 cSilhouetteColor = 0;
  cSilhouetteColor      += c0 * cSilhoueteMask.x;
  cSilhouetteColor      += c1 * cSilhoueteMask.y;
  cSilhouetteColor      += c2 * cSilhoueteMask.z;
  cSilhouetteColor.xyz  /= dot(cSilhoueteMask.xyz, 1.0f) + 0.0001f;

  half fOpacity = saturate(dot(c.xyz + c0.xyz + c1.xyz + c2.xyz, 10.0f));
  OUT.Color.xyz = (cSilhouetteColor * 0.5f * fOpacity * fSilhouete) + c * 0.2f * psParams[0].w;

  return OUT;
}

pixout BinocularViewGlowPS(vtxOut IN)
{
  pixout OUT = (pixout)1;
  half4 c            = tex2D(_tex0, IN.baseTC);
  half4 cSilhouettes = tex2D(_tex1, IN.baseTC);
  OUT.Color          = max(cSilhouettes - c * 0.2f, 0.0f);
  return OUT;
}

pixout BinocularViewFinalPS(vtxOut IN)
{
  pixout OUT = (pixout)1;

  half4 cScreen             = tex2D(_tex0, IN.baseTC);
  half4 cSilhouettes        = tex2D(_tex1, IN.baseTC);
  half4 cSilhouettesBlurred = tex2D(_tex2, IN.baseTC);

  half fInterlation = abs(frac(IN.baseTC.y * PS_ScreenSize.y * 0.25f) * 2.0f - 1.0f) * 0.5f + 0.5f;
  half fVigneti     = saturate(1.0f - length(IN.baseTC.xy - 0.5f) * 0.6f);

  OUT.Color  = fInterlation * 1.5f * (cScreen * half4(0.7f, 0.8f, 1.0f, 1.0f)) + (cSilhouettesBlurred + cSilhouettes * saturate(fInterlation * 2.0f - 1.0f) * 1.5f) * 0.666f;
  OUT.Color *= fVigneti;
  OUT.Color  = lerp(cScreen, OUT.Color, psParams[0].w);

  return OUT;
}

pixout BinocularViewFinalNoTintingPS(vtxOut IN)
{
  pixout OUT = (pixout)1;

  half4 cScreen             = tex2D(_tex0, IN.baseTC);
  half4 cSilhouettes        = tex2D(_tex1, IN.baseTC);
  half4 cSilhouettesBlurred = tex2D(_tex2, IN.baseTC);

  OUT.Color = cScreen + (cSilhouettesBlurred * 0.5f + dot(cSilhouettes.xyz, 0.33f) * 0.1f);
  OUT.Color = lerp(cScreen, OUT.Color, psParams[0].w);

  return OUT;
}

technique BinocularView
{
  pass p0
  {
    VertexShader = compile vs_Auto BinocularViewVS();
    PixelShader  = compile ps_Auto BinocularViewPS();
    CullMode     = None;
  }
}

