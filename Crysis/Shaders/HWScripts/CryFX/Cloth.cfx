        "ShaderDrawType = Light;"
        "ShaderType = General;";
>;

// Custom shading pass structure

struct fragPassCustom
{
    half3 vTangent;
    half3 vBinormal;

    half  fFresnel;
    half  fFuzzyNess;
    half3 cFuzzy;
    half3 cFuzzyAcc;

    half  fSpecMultiplier;
    half  fDifExponent;
    half2 vSurfaceRoughness;

    half3 cLuminanceDiffuseFresnel;

    // mp specific
    half3 cReflectEffectAmb;
    half3 cDiffuseAccum;
    half  fFresnelScaleAccum;

    half  fCloakAmount;
};

struct fragLightPassCustom
{
};

#include "ShadeLib.cfi"

