// Shader global descriptions

float Script : STANDARDSGLOBAL
<
    string Script =
        "Public;"
        "SupportsAttrInstancing;"
#if %DETAIL_BUMP_MAPPING
        "DetailBumpMapping;"
#endif
#if %WIND_BENDING
        "VT_WindBending;"
