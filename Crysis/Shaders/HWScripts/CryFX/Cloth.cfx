// Samplers

SUBSURFACEMAP
DECALMAP
OPACITYMAP
ENVIRONMENTMAP
ENVIRONMENTCUBEMAP

sampler2D customMapSampler = sampler_state
{
    Texture    = $CustomMap;
    sRGBLookup = true;
};

sampler2D chameleonMapSampler = sampler_state
{
    Texture   = $CloakRT;
    MinFilter = LINEAR;
    MagFilter = LINEAR;
    MipFilter = LINEAR;
    AddressU  = Wrap;
    AddressV  = Wrap;
};

sampler2D cloakFluidSampler = sampler_state
{
    Texture   = Textures/defaults/noise.dds;
    MinFilter = LINEAR;
    MagFilter = LINEAR;
    MipFilter = LINEAR;
    AddressU  = Wrap;
    AddressV  = Wrap;
};

sampler2D fuzzyPowSampler = sampler_state
{
    Texture   = textures/defaults/fuzzy_pow_sampler_merged.dds;
    MinFilter = LINEAR;
    MagFilter = LINEAR;
    MipFilter = NONE;
    AddressU  = Clamp;
    AddressV  = Clamp;
};

